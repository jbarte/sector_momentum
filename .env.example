# Supabase direct connection string (port 5432, not the pooler)
# Get from: Supabase Dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Reddit public JSON API — no OAuth needed, but a descriptive User-Agent is required.
# Replace with your own Reddit username.
REDDIT_USER_AGENT=sector-momentum-scanner/1.0 by u/your_reddit_username

# Supabase service-role key — required to write the private db-backups Storage bucket.
# Get from: Supabase Dashboard → Project Settings → API → service_role key.
# (Storage URL is derived from DATABASE_URL; set SUPABASE_URL to override.)
SUPABASE_SERVICE_KEY=your-service-role-key

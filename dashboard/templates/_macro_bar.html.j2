{% if macro %}
<div class="macro-bar">
  <span class="macro-item">
    <span class="macro-label">SPY</span>
    <span class="macro-value {{ 'macro-up' if macro.spy_above else 'macro-down' }}">{{ "%+.1f"|format(macro.spy_distance_pct) }}%</span>
    <span class="macro-sub" data-i18n="macro_vs_200dma">vs 200-DMA</span>
  </span>
  <span class="macro-sep"></span>
  <span class="macro-item">
    <span class="macro-label">VIX</span>
    <span class="macro-value">{{ "%.1f"|format(macro.vix_last) }}</span>
    <span class="macro-band macro-band-{{ macro.vix_band|lower }}" data-i18n="macro_vix_{{ macro.vix_band|lower }}">{{ macro.vix_band }}</span>
  </span>
</div>
{% endif %}

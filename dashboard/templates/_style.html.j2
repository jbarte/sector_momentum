@import url('https://fonts.googleapis.com/css2?family=Familjen+Grotesk:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --beige-50:  #FAF7F0;
  --beige-100: #F5F0E6;
  --beige-200: #EDE6D6;
  --beige-300: #DFD5BE;
  --beige-400: #C4B89A;
  --beige-500: #8F8568;
  --beige-600: #5E5742;
  --beige-700: #3E392B;
  --beige-900: #1F1C15;

  --green-100: #E2EBD9;
  --green-300: #A9BF95;
  --green-400: #8FA77A;
  --green-600: #5A6F49;
  --green-700: #455636;

  --terra-400: #BF6F50;
  --terra-500: #A55A3C;

  --bg:           var(--beige-100);
  --bg-raised:    var(--beige-50);
  --bg-sunken:    var(--beige-200);
  --fg1:          var(--beige-900);
  --fg2:          var(--beige-700);
  --fg3:          var(--beige-600);
  --fg4:          var(--beige-500);
  --brand-strong: var(--green-600);
  --border:       var(--beige-300);
  --border-soft:  var(--beige-200);
  --up:           var(--green-600);
  --down:         var(--terra-500);

  --font-display: 'Familjen Grotesk', 'Helvetica Neue', system-ui, sans-serif;
  --font-body:    'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
  --font-mono:    'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace;

  --radius-sm:   4px;
  --radius-md:   8px;
  --radius-lg:   14px;
  --radius-pill: 999px;

  --shadow-xs: 0 1px 2px rgba(62,57,43,0.06);
  --shadow-sm: 0 1px 2px rgba(62,57,43,0.05), 0 2px 6px rgba(62,57,43,0.04);

  --ease-standard: cubic-bezier(0.2,0.6,0.2,1);
  --duration-fast: 140ms;
}

html, body {
  background: var(--bg);
  color: var(--fg2);
  font-family: var(--font-body);
  font-size: 14px;
  line-height: 1.5;
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
}

/* =========================================================
   Header
   ========================================================= */
header {
  background: var(--bg-raised);
  border-bottom: 1px solid var(--border);
  padding: 16px 28px;
  display: flex;
  align-items: baseline;
  gap: 16px;
  flex-wrap: wrap;
}
header h1 {
  font-family: var(--font-display);
  font-size: 22px;
  font-weight: 600;
  color: var(--fg1);
  letter-spacing: -0.02em;
  line-height: 1;
}
.scan-date {
  font-size: 12px;
  color: var(--fg4);
}
.disclaimer {
  margin-left: auto;
  font-size: 11px;
  color: var(--fg4);
  border: 1px solid var(--border-soft);
  border-radius: var(--radius-pill);
  padding: 3px 10px;
}
.lang-toggle {
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--fg3);
  background: var(--bg-raised);
  border: 1px solid var(--border);
  border-radius: var(--radius-pill);
  padding: 3px 12px;
  cursor: pointer;
  transition: color var(--duration-fast) var(--ease-standard),
              border-color var(--duration-fast) var(--ease-standard);
}
.lang-toggle:hover { color: var(--brand-strong); border-color: var(--brand-strong); }

/* =========================================================
   Macro regime bar — SPY vs 200-DMA + VIX band, below header.
   ========================================================= */
.macro-bar { display:flex; align-items:center; justify-content:center; gap:20px; padding:6px 16px; font-size:12px; font-family:var(--font-body); color:var(--fg2); border-bottom:1px solid var(--border); }
.macro-item { display:flex; align-items:center; gap:6px; }
.macro-label { font-weight:600; color:var(--fg1); }
.macro-value { font-variant-numeric:tabular-nums; }
.macro-sub { font-size:11px; }
.macro-sep { width:1px; height:14px; background:var(--border); }
.macro-up { color:var(--up); }
.macro-down { color:var(--down); }
.macro-band { font-size:11px; font-weight:600; padding:1px 8px; border-radius:var(--radius-pill); }
.macro-band-calm { color:var(--up); background:color-mix(in srgb, var(--up) 12%, transparent); }
.macro-band-elevated { color:var(--fg1); background:color-mix(in srgb, var(--fg1) 10%, transparent); }
.macro-band-stressed { color:var(--down); background:color-mix(in srgb, var(--down) 12%, transparent); }

/* =========================================================
   Segment toggle (Sectors ⇄ Sentiment) — top-level page switcher,
   distinct from the sector tab bar below it.
   ========================================================= */
.segment-toggle {
  display: inline-flex;
  background: var(--beige-200);
  border-radius: var(--radius-pill);
  padding: 3px;
  gap: 2px;
}
.segment-btn {
  display: inline-flex;
  align-items: center;
  padding: 5px 14px;
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: 500;
  color: var(--fg3);
  text-decoration: none;
  border-radius: var(--radius-pill);
  white-space: nowrap;
  cursor: pointer;
  /* Reset <button> UA chrome so button-based toggles match <a>/<span> ones. */
  border: none;
  background: transparent;
  -webkit-appearance: none;
  appearance: none;
  transition: color var(--duration-fast) var(--ease-standard),
              background var(--duration-fast) var(--ease-standard);
}
.segment-btn:hover { color: var(--fg1); }
.segment-btn.active {
  background: var(--bg-raised);
  color: var(--brand-strong);
  font-weight: 600;
  box-shadow: var(--shadow-xs);
  cursor: default;
}

/* =========================================================
   Tab bar
   ========================================================= */
.tabs {
  display: flex;
  background: var(--bg-raised);
  border-bottom: 1px solid var(--border);
  overflow-x: auto;
  padding: 0 24px;
}
.tab-btn {
  text-decoration: none;
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  color: var(--fg4);
  cursor: pointer;
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 500;
  padding: 11px 16px;
  white-space: nowrap;
  transition: color var(--duration-fast) var(--ease-standard),
              border-color var(--duration-fast) var(--ease-standard);
}
.tab-btn:hover { color: var(--fg2); }
.tab-btn.active {
  color: var(--brand-strong);
  border-bottom-color: var(--brand-strong);
}

/* =========================================================
   Tab content panels
   ========================================================= */
.tab-panel { display: none; padding: 24px 28px; }
.tab-panel.active { display: block; }

/* =========================================================
   Leaderboard table
   ========================================================= */
.table-wrap {
  overflow-x: auto;
  border-radius: var(--radius-lg);
  border: 1px solid var(--border-soft);
  background: var(--bg-raised);
  box-shadow: var(--shadow-xs);
}
.scan-index { margin-bottom: 20px; }
.scan-index .active-scan { background: var(--green-100); }
.showing-badge { color: var(--green-700); font-weight: 600; font-size: 0.8em; white-space: nowrap; }
.scan-index tr[data-scan-id] { cursor: pointer; }
.scan-index tr[data-scan-id]:not(.active-scan):hover { background: var(--bg-sunken); }
.scan-index tr[data-scan-id]:focus-visible { outline: 2px solid var(--brand-strong); outline-offset: -2px; }
#scan-history-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 16px;
  margin-bottom: 8px;
  background: var(--bg-raised);
  border-left: 3px solid var(--brand-strong);
  border-radius: var(--radius-sm);
  font-size: 13px;
  color: var(--fg3);
}
#scan-history-banner a {
  color: var(--brand-strong);
  font-weight: 500;
  text-decoration: none;
}
#scan-history-banner a:hover { text-decoration: underline; }
#scan-digest-banner {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 6px 16px;
  padding: 8px 16px;
  margin-bottom: 8px;
  background: var(--bg-raised);
  border-left: 3px solid var(--brand-strong);
  border-radius: var(--radius-sm);
  font-size: 13px;
  color: var(--fg3);
}
.digest-cluster { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
.digest-chips { display: flex; gap: 8px; flex-wrap: wrap; }
.digest-chip { white-space: nowrap; }
table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
}
thead tr {
  background: var(--bg-sunken);
  border-bottom: 1px solid var(--border);
}
thead th {
  padding: 10px 16px;
  text-align: left;
  color: var(--fg4);
  font-size: 10px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.10em;
  cursor: pointer;
  user-select: none;
  white-space: nowrap;
}
thead th:hover { color: var(--fg2); }
thead th.sort-asc::after  { content: " ▲"; font-size: 0.75em; }
thead th.sort-desc::after { content: " ▼"; font-size: 0.75em; }
tbody tr { border-bottom: 1px dashed var(--border-soft); }
tbody tr:last-child { border-bottom: none; }
tbody td {
  padding: 11px 16px;
  vertical-align: middle;
  color: var(--fg2);
}
tbody td:nth-child(n+4) {
  font-family: var(--font-mono);
  font-size: 12px;
}
.rank-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 26px;
  height: 26px;
  border-radius: 50%;
  background: var(--bg-sunken);
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 12px;
  color: var(--fg3);
}
.rank-badge.top3 {
  background: var(--green-100);
  color: var(--green-700);
}
.arrow.up   { color: var(--up);   font-size: 11px; }
.arrow.down { color: var(--down); font-size: 11px; }
.tag-region {
  display: inline-block;
  font-size: 10px;
  font-weight: 500;
  padding: 2px 8px;
  border-radius: var(--radius-pill);
  background: var(--beige-200);
  color: var(--fg3);
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

/* Trajectory badges */
.traj-badge {
  display: inline-block;
  font-weight: 600;
  font-size: 0.82em;
  letter-spacing: 0.02em;
  padding: 2px 7px;
  border-radius: 4px;
  font-family: var(--font-mono);
}
.traj-badge.traj-strong_up   { color: var(--up); background: color-mix(in srgb, var(--up) 15%, transparent); }
.traj-badge.traj-up          { color: var(--up); background: color-mix(in srgb, var(--up) 8%, transparent); }
.traj-badge.traj-flat        { color: var(--fg4); background: color-mix(in srgb, var(--fg4) 10%, transparent); }
.traj-badge.traj-down        { color: var(--down); background: color-mix(in srgb, var(--down) 8%, transparent); }
.traj-badge.traj-strong_down { color: var(--down); background: color-mix(in srgb, var(--down) 15%, transparent); }

/* =========================================================
   Plotly chart containers
   ========================================================= */
.chart-container {
  background: var(--bg-raised);
  border: 1px solid var(--border-soft);
  border-radius: var(--radius-lg);
  overflow: hidden;
  min-height: 420px;
  box-shadow: var(--shadow-xs);
}

/* =========================================================
   Drill-down panel
   ========================================================= */
.drilldown-controls {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
  flex-wrap: wrap;
}
.drilldown-controls label {
  color: var(--fg4);
  font-size: 10px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.10em;
}
select.sector-select {
  background: var(--bg-raised);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  color: var(--fg1);
  font-family: var(--font-body);
  font-size: 13px;
  padding: 7px 12px;
  cursor: pointer;
  min-width: 220px;
  outline: none;
  transition: border-color var(--duration-fast) var(--ease-standard);
}
select.sector-select:focus {
  border-color: var(--green-400);
  box-shadow: 0 0 0 3px rgba(143,167,122,0.2);
}

/* Tab interpretation guides */
.tab-guide {
  background: color-mix(in srgb, var(--bg-sunken) 60%, transparent);
  border: 1px solid var(--border);
  border-radius: 6px;
  margin-bottom: 18px;
  padding: 0;
  font-size: 0.875rem;
}
.tab-guide summary {
  padding: 10px 16px;
  cursor: pointer;
  color: var(--fg3);
  font-weight: 500;
  list-style: none;
  display: flex;
  align-items: center;
  gap: 8px;
  user-select: none;
}
.tab-guide summary::before {
  content: "▶";
  font-size: 0.65em;
  transition: transform 0.15s;
}
.tab-guide[open] summary::before {
  transform: rotate(90deg);
}
.tab-guide-body {
  padding: 0 18px 16px 18px;
  color: var(--fg2);
  line-height: 1.65;
}
.tab-guide-body h4 {
  margin: 12px 0 4px;
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--fg4);
}
.tab-guide-body ul {
  margin: 4px 0 0 0;
  padding-left: 18px;
}
.tab-guide-body li {
  margin-bottom: 3px;
}
.tab-guide-body .signal-hi { color: var(--up); font-weight: 600; }
.tab-guide-body .signal-lo { color: var(--down); font-weight: 600; }

/* =========================================================
   Guide panel
   ========================================================= */
.guide {
  max-width: 680px;
  line-height: 1.7;
}
.guide h2 {
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: 500;
  color: var(--fg1);
  letter-spacing: -0.01em;
  margin-top: 28px;
  margin-bottom: 8px;
}
.guide h2:first-child { margin-top: 0; }
.guide p { color: var(--fg3); margin-bottom: 10px; font-size: 14px; }
.guide ul { padding-left: 18px; color: var(--fg3); margin-bottom: 10px; font-size: 14px; }
.guide li { margin-bottom: 5px; }
.guide strong { color: var(--fg2); font-weight: 500; }

/* =========================================================
   Responsive
   ========================================================= */
@media (max-width: 600px) {
  header { padding: 12px 16px; }
  .tab-panel { padding: 14px 16px; }
  .tabs { padding: 0 8px; }
}

/* =========================================================
   Leaderboard row breakdown
   ========================================================= */
.leaderboard-row { cursor: pointer; }
.leaderboard-row:hover { background: rgba(143,167,122,0.06); }
.chevron {
  font-size: 0.6em;
  color: var(--fg4);
  margin-left: 5px;
  display: inline-block;
  transition: transform var(--duration-fast) var(--ease-standard);
}
.breakdown-row { display: none; }
.breakdown-row.open { display: table-row; }
.breakdown-inner {
  padding: 16px 20px;
  background: var(--bg-sunken);
  border-top: 1px solid var(--border-soft);
}
.breakdown-grid {
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: 24px;
  align-items: start;
}
@media (max-width: 700px) { .breakdown-grid { grid-template-columns: 1fr; } }

/* Score tree */
.score-tree {
  font-family: var(--font-mono);
  font-size: 12px;
  line-height: 2;
}
.st-row { display: flex; align-items: baseline; gap: 4px; }
.st-top .st-label { font-weight: 600; color: var(--fg1); }
.st-top .st-val   { font-weight: 600; color: var(--brand-strong); }
.st-conn  { color: var(--fg4); white-space: pre; min-width: 2.5em; }
.st-label { color: var(--fg3); }
.st-wt    { color: var(--fg4); font-size: 0.9em; }
.st-val   { color: var(--fg2); margin-left: auto; min-width: 48px; text-align: right; }
.st-meta  { color: var(--fg4); font-size: 0.85em; margin-left: 4px; }
.bd-footer {
  margin-top: 10px;
  font-size: 11px;
  color: var(--fg4);
  border-top: 1px dashed var(--border-soft);
  padding-top: 8px;
  font-family: var(--font-mono);
}

/* Signal tables */
.sig-section { margin-bottom: 12px; }
.sig-title {
  font-size: 10px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.10em;
  color: var(--fg4);
  margin-bottom: 5px;
}
.sig-table { border-collapse: collapse; width: 100%; font-size: 12px; }
.sig-table td { padding: 3px 6px; vertical-align: middle; }
.sig-label { color: var(--fg3); white-space: nowrap; }
.sig-raw   { color: var(--fg2); font-family: var(--font-mono); text-align: right; min-width: 54px; }
.sig-bar   { padding: 0 8px; }
.sig-z     { color: var(--fg4); font-family: var(--font-mono); text-align: right; min-width: 46px; }
.z-bar-wrap {
  display: inline-block;
  width: 60px; height: 6px;
  background: var(--beige-300);
  border-radius: var(--radius-pill);
  vertical-align: middle;
}
.z-bar {
  display: inline-block;
  height: 6px;
  border-radius: var(--radius-pill);
}
.sig-chip   { font-size: 11px; }
.sig-chip.bull { color: var(--green-600); }
.sig-chip.bear { color: var(--terra-500); }
.sig-chip.neut { color: var(--fg4); }
/* Signal tooltip */
.sig-tip {
  border-bottom: 1px dashed var(--fg4);
  cursor: help;
  position: relative;
}
.sig-tip::after {
  content: attr(data-tip);
  display: none;
  position: absolute;
  left: 0; top: calc(100% + 6px);
  min-width: 220px; max-width: 320px;
  background: var(--bg-raised);
  border: 1px solid var(--border);
  color: var(--fg2);
  font-size: 0.78rem;
  font-family: var(--font-body);
  line-height: 1.55;
  padding: 7px 11px;
  border-radius: var(--radius-md);
  box-shadow: 0 3px 10px rgba(0,0,0,0.12);
  white-space: normal;
  z-index: 200;
  pointer-events: none;
}
.sig-tip:hover::after, .sig-tip:focus::after { display: block; }
/* Setup badges (entry / exit) */
.setup-badge {
  display: inline-block;
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.03em;
  padding: 1px 6px;
  border-radius: var(--radius-pill);
  margin-left: 6px;
  vertical-align: middle;
}
.setup-badge.entry {
  color: var(--up);
  background: color-mix(in srgb, var(--up) 12%, transparent);
  border: 1px solid color-mix(in srgb, var(--up) 30%, transparent);
}
.setup-badge.exit {
  color: var(--down);
  background: color-mix(in srgb, var(--down) 12%, transparent);
  border: 1px solid color-mix(in srgb, var(--down) 30%, transparent);
}
.sig-info {
  font-size: 11px;
  color: var(--fg4);
  margin-top: 8px;
  border-top: 1px dashed var(--border-soft);
  padding-top: 6px;
}
.info-lbl { font-weight: 500; }

/* Instruments table */
.bd-instruments {
  margin-top: 14px;
  border-top: 1px dashed var(--border-soft);
  padding-top: 10px;
}
.etf-table { border-collapse: collapse; width: 100%; font-size: 12px; }
.etf-table th {
  font-size: 10px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--fg4);
  border-bottom: 1px solid var(--border-soft);
  padding: 2px 8px 5px;
  text-align: left;
}
.etf-table td { padding: 4px 8px; vertical-align: middle; }
.etf-ticker { font-family: var(--font-mono); font-weight: 600; color: var(--fg2); white-space: nowrap; }
.etf-name   { color: var(--fg3); }
.etf-ter    { font-family: var(--font-mono); color: var(--fg4); text-align: right; white-space: nowrap; }
.etf-isin   { font-family: var(--font-mono); font-size: 11px; color: var(--fg4); }
.etf-match  { font-size: 11px; text-transform: capitalize; white-space: nowrap; }
.etf-match-exact   { color: var(--up); }
.etf-match-close   { color: var(--fg3); }
.etf-match-partial { color: var(--fg4); font-style: italic; }
.etf-link a { color: var(--brand-strong); text-decoration: none; }
.etf-link a:hover { color: var(--brand-strong); }

/* =========================================================
   Sentiment toggle control
   ========================================================= */
.sentiment-control { display:flex; align-items:center; gap:16px; margin:8px 0 12px; font-size:0.9em; color:#3E392B; }
.sentiment-control input[type=number] { width:52px; }
.sentiment-control .sw-weight[data-disabled="true"] { opacity:0.45; }
.tab-note { font-size:0.8em; color:#8C8370; margin:0 0 8px; }

/* =========================================================
   Guide modal overlay
   ========================================================= */
.guide-open-btn {
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--fg3);
  background: var(--bg-raised);
  border: 1px solid var(--border);
  border-radius: var(--radius-pill);
  padding: 3px 12px;
  cursor: pointer;
  transition: color var(--duration-fast) var(--ease-standard),
              border-color var(--duration-fast) var(--ease-standard);
}
.guide-open-btn:hover { color: var(--brand-strong); border-color: var(--brand-strong); }

.guide-overlay {
  position: fixed;
  inset: 0;
  z-index: 1000;
  background: rgba(31,28,21,0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px 16px;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.25s var(--ease-standard), visibility 0.25s;
}
.guide-overlay.open { opacity: 1; visibility: visible; }

.guide-modal {
  position: relative;
  width: 100%;
  max-width: 540px;
  max-height: calc(100vh - 48px);
  display: flex;
  flex-direction: column;
  transform: translateY(12px);
  transition: transform 0.3s var(--ease-standard);
}
.guide-overlay.open .guide-modal { transform: translateY(0); }

.guide-close {
  position: absolute;
  top: 10px;
  right: 10px;
  z-index: 2;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-raised);
  border: 1px solid var(--border);
  border-radius: 50%;
  font-size: 20px;
  line-height: 1;
  color: var(--fg3);
  cursor: pointer;
  transition: color var(--duration-fast), border-color var(--duration-fast);
}
.guide-close:hover { color: var(--fg1); border-color: var(--fg4); }

.guide-viewport {
  overflow: hidden;
  border-radius: var(--radius-lg);
  background: var(--bg-raised);
  border: 1px solid var(--border);
  box-shadow: var(--shadow-sm), 0 8px 32px rgba(31,28,21,0.12);
}

.guide-track {
  display: flex;
  transition: transform 0.42s var(--ease-standard);
  will-change: transform;
}

.guide-card { flex: 0 0 100%; min-width: 0; }

.guide-card-illust {
  background: var(--bg-sunken);
  height: 196px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1px solid var(--border-soft);
  padding: 24px 32px;
  overflow: hidden;
}
.guide-card-illust svg { display: block; width: 100%; max-width: 340px; height: auto; }

.guide-card-body { padding: 28px 32px 24px; }

.guide-eyebrow {
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--brand-strong);
  margin-bottom: 6px;
}

.guide-card-body h2 {
  font-family: var(--font-display);
  font-size: 24px;
  font-weight: 600;
  line-height: 1.2;
  letter-spacing: -0.01em;
  color: var(--fg1);
  margin-bottom: 14px;
  text-wrap: balance;
}

.guide-card-body p { color: var(--fg3); font-size: 14px; line-height: 1.65; }
.guide-card-body p + p { margin-top: 10px; }
.guide-card-body strong { color: var(--fg2); font-weight: 600; }

.guide-card-body ul { margin-top: 10px; padding: 0; list-style: none; }
.guide-card-body li {
  position: relative;
  padding-left: 16px;
  font-size: 14px;
  line-height: 1.55;
  color: var(--fg3);
}
.guide-card-body li + li { margin-top: 5px; }
.guide-card-body ul + p { margin-top: 14px; }
.guide-card-body li::before {
  content: '';
  position: absolute;
  left: 0; top: 9px;
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--brand-strong);
  opacity: 0.45;
}

.guide-tip {
  margin-top: 14px;
  padding: 10px 14px;
  background: rgba(90,111,73,0.07);
  border-radius: var(--radius-md);
  font-size: 13px;
  line-height: 1.55;
  color: var(--fg3);
}
.guide-tip strong { color: var(--brand-strong); }

.guide-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12px;
  padding: 0 2px;
  gap: 12px;
}

.guide-nav-btn {
  appearance: none;
  background: var(--bg-raised);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  width: 40px; height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: var(--fg1);
  font-size: 20px;
  line-height: 1;
  flex-shrink: 0;
  transition: background var(--duration-fast), border-color var(--duration-fast), color var(--duration-fast);
}
.guide-nav-btn:hover:not(:disabled) {
  background: rgba(90,111,73,0.07);
  border-color: var(--brand-strong);
  color: var(--brand-strong);
}
.guide-nav-btn:disabled { opacity: 0.25; cursor: default; }
.guide-nav-btn:focus-visible { outline: 2px solid var(--brand-strong); outline-offset: 2px; }

.guide-dots { display: flex; gap: 6px; align-items: center; }
.guide-dot {
  appearance: none;
  width: 7px; height: 7px;
  border-radius: 4px;
  background: var(--border);
  border: none;
  cursor: pointer;
  padding: 0;
  transition: all 0.28s var(--ease-standard);
}
.guide-dot:hover { background: var(--fg4); }
.guide-dot.active { background: var(--brand-strong); width: 22px; }
.guide-dot:focus-visible { outline: 2px solid var(--brand-strong); outline-offset: 2px; }

.guide-counter {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--fg4);
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
  min-width: 38px;
  text-align: center;
}

.guide-hint {
  text-align: center;
  margin-top: 10px;
  font-size: 11px;
  color: var(--fg4);
  opacity: 0.6;
}
.guide-hint kbd {
  font-family: var(--font-mono);
  font-size: 10px;
  background: var(--bg-raised);
  border: 1px solid var(--border);
  border-radius: 3px;
  padding: 1px 5px;
  margin: 0 1px;
}

@media (prefers-reduced-motion: reduce) {
  .guide-track { transition: none; }
  .guide-dot { transition: none; }
  .guide-overlay { transition: none; }
  .guide-modal { transition: none; }
}

/* --- Sentiment: seasonal + rising queries --- */
.seasonal-hi { color: var(--up); }
.seasonal-lo { color: var(--down); }
.has-rising { cursor: pointer; }
.has-rising:hover { background: var(--bg-raised); }
.has-rising:focus-visible { outline: 2px solid var(--brand-strong); outline-offset: -2px; }
.rising-toggle {
  width: 1.2em;
  text-align: center;
  color: var(--fg4);
  font-size: 0.7em;
  transition: transform 0.15s;
  user-select: none;
}
.has-rising.open .rising-toggle { transform: rotate(90deg); }
.rising-panel td { padding: 0 !important; border-bottom: none !important; }
.rising-inner {
  padding: 8px 16px 12px 36px;
  background: var(--bg-sunken);
  border-bottom: 1px solid var(--border-soft);
}
.rising-inner strong { font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--fg4); }
.rising-table {
  width: auto;
  margin-top: 4px;
  font-size: 12px;
}
.rising-table thead th {
  padding: 4px 12px;
  font-size: 9px;
  cursor: default;
}
.rising-table tbody td { padding: 4px 12px; }

@media (max-width: 520px) {
  .guide-card-body { padding: 22px 20px 20px; }
  .guide-card-body h2 { font-size: 21px; }
  .guide-card-illust { height: 160px; padding: 20px 24px; }
}

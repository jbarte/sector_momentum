@import url('https://fonts.googleapis.com/css2?family=Familjen+Grotesk:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --beige-50:  #FAF7F0;
  --beige-100: #F5F0E6;
  --beige-200: #EDE6D6;
  --beige-300: #DFD5BE;
  --beige-400: #C4B89A;
  --beige-500: #8F8568;
  --beige-600: #5E5742;
  --beige-700: #3E392B;
  --beige-900: #1F1C15;

  --green-100: #E2EBD9;
  --green-300: #A9BF95;
  --green-400: #8FA77A;
  --green-600: #5A6F49;
  --green-700: #455636;

  --terra-400: #BF6F50;
  --terra-500: #A55A3C;

  --bg:           var(--canvas);
  --bg-raised:    var(--beige-50);
  --bg-sunken:    var(--beige-200);
  --fg1:          var(--beige-900);
  --fg2:          var(--beige-700);
  --fg3:          var(--beige-600);
  --fg4:          var(--beige-500);
  --brand-strong: var(--green-600);
  --border:       var(--beige-300);
  --border-soft:  var(--beige-200);
  --up:           var(--green-600);
  --down:         var(--terra-500);

  --font-display: 'Familjen Grotesk', 'Helvetica Neue', system-ui, sans-serif;
  --font-body:    'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
  --font-mono:    'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace;

  --radius-sm:   4px;
  --radius-md:   8px;
  --radius-lg:   14px;
  --radius-pill: 999px;

  --shadow-xs: 0 1px 2px rgba(62,57,43,0.06);
  --shadow-sm: 0 1px 2px rgba(62,57,43,0.05), 0 2px 6px rgba(62,57,43,0.04);
  --canvas:      #f1ecdf;
  --surface:     #ffffff;
  --shadow-card: 0 1px 5px rgba(60,55,40,0.10);

  --ease-standard: cubic-bezier(0.2,0.6,0.2,1);
  --duration-fast: 140ms;
}

html, body {
  background: var(--bg);
  color: var(--fg2);
  font-family: var(--font-body);
  font-size: 14px;
  line-height: 1.5;
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
}

/* =========================================================
   Command bar
   ========================================================= */
.command-bar {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 28px;
  flex-wrap: wrap;
}
.command-bar h1 {
  font-family: var(--font-display);
  font-size: 16px;
  font-weight: 600;
  color: var(--fg1);
  letter-spacing: -0.02em;
  line-height: 1;
  white-space: nowrap;
}
.meta-cluster {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-left: auto;
}
.scan-meta {
  font-size: 11px;
  color: var(--fg4);
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
}
.lang-toggle {
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--fg3);
  background: transparent;
  border: 1px solid var(--border);
  border-radius: var(--radius-pill);
  padding: 3px 12px;
  cursor: pointer;
  transition: color var(--duration-fast) var(--ease-standard),
              border-color var(--duration-fast) var(--ease-standard);
}
.lang-toggle:hover { color: var(--brand-strong); border-color: var(--brand-strong); }

/* =========================================================
   Chips (macro indicators in command bar)
   ========================================================= */
.chip {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 500;
  padding: 2px 8px;
  border-radius: var(--radius-sm);
  white-space: nowrap;
  cursor: default;
  font-variant-numeric: tabular-nums;
}
.chip-up   { background: color-mix(in srgb, var(--up) 12%, transparent); color: var(--up); }
.chip-down { background: color-mix(in srgb, var(--down) 12%, transparent); color: var(--down); }
.chip-calm      { background: color-mix(in srgb, var(--up) 12%, transparent); color: var(--up); }
.chip-elevated  { background: color-mix(in srgb, var(--fg1) 8%, transparent); color: var(--fg1); }
.chip-stressed  { background: color-mix(in srgb, var(--down) 12%, transparent); color: var(--down); }

/* =========================================================
   Card shell
   ========================================================= */
.card {
  background: var(--surface);
  border-radius: 10px;
  box-shadow: var(--shadow-card);
  margin: 16px 28px 24px;
  overflow: hidden;
}
.card > .tabs {
  background: var(--surface);
  border-bottom: 1px solid var(--border-soft);
  padding: 0 20px;
  border-radius: 10px 10px 0 0;
}
.card > .tab-panel { padding: 20px 24px; }

/* =========================================================
   Segment toggle (Sectors ⇄ Sentiment) — top-level page switcher,
   distinct from the sector tab bar below it.
   ========================================================= */
.segment-toggle {
  display: inline-flex;
  background: var(--beige-200);
  border-radius: var(--radius-pill);
  padding: 3px;
  gap: 2px;
}
.segment-btn {
  display: inline-flex;
  align-items: center;
  padding: 5px 14px;
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: 500;
  color: var(--fg3);
  text-decoration: none;
  border-radius: var(--radius-pill);
  white-space: nowrap;
  cursor: pointer;
  /* Reset <button> UA chrome so button-based toggles match <a>/<span> ones. */
  border: none;
  background: transparent;
  -webkit-appearance: none;
  appearance: none;
  transition: color var(--duration-fast) var(--ease-standard),
              background var(--duration-fast) var(--ease-standard);
}
.segment-btn:hover { color: var(--fg1); }
.segment-btn.active {
  background: var(--bg-raised);
  color: var(--brand-strong);
  font-weight: 600;
  box-shadow: var(--shadow-xs);
  cursor: default;
}

/* =========================================================
   Tab bar
   ========================================================= */
.tabs {
  display: flex;
  background: var(--bg-raised);
  border-bottom: 1px solid var(--border);
  overflow-x: auto;
  padding: 0 24px;
}
.tab-btn {
  text-decoration: none;
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  color: var(--fg4);
  cursor: pointer;
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 500;
  padding: 11px 16px;
  white-space: nowrap;
  transition: color var(--duration-fast) var(--ease-standard),
              border-color var(--duration-fast) var(--ease-standard);
}
.tab-btn:hover { color: var(--fg2); }
.tab-btn.active {
  color: var(--brand-strong);
  border-bottom-color: var(--brand-strong);
}

/* =========================================================
   Tab content panels
   ========================================================= */
.tab-panel { display: none; padding: 24px 28px; }
.tab-panel.active { display: block; }

/* =========================================================
   Leaderboard table
   ========================================================= */
.table-wrap {
  overflow-x: auto;
  border-radius: var(--radius-lg);
  border: 1px solid var(--border-soft);
  background: var(--bg-raised);
  box-shadow: var(--shadow-xs);
}
.scan-index { margin-bottom: 20px; }
.scan-index .active-scan { background: var(--green-100); }
.showing-badge { color: var(--green-700); font-weight: 600; font-size: 0.8em; white-space: nowrap; }
.scan-index tr[data-scan-id] { cursor: pointer; }
.scan-index tr[data-scan-id]:not(.active-scan):hover { background: var(--bg-sunken); }
.scan-index tr[data-scan-id]:focus-visible { outline: 2px solid var(--brand-strong); outline-offset: -2px; }
#scan-history-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 16px;
  margin-bottom: 8px;
  background: var(--bg-raised);
  border-left: 3px solid var(--brand-strong);
  border-radius: var(--radius-sm);
  font-size: 13px;
  color: var(--fg3);
}
#scan-history-banner a {
  color: var(--brand-strong);
  font-weight: 500;
  text-decoration: none;
}
#scan-history-banner a:hover { text-decoration: underline; }
#scan-digest-banner {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 6px 16px;
  padding: 8px 16px;
  margin-bottom: 8px;
  background: var(--bg-raised);
  border-left: 3px solid var(--brand-strong);
  border-radius: var(--radius-sm);
  font-size: 13px;
  color: var(--fg3);
}
.digest-cluster { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
.digest-chips { display: flex; gap: 8px; flex-wrap: wrap; }
.digest-chip { white-space: nowrap; }
.digest-collapsed .digest-cluster[data-cluster="up"],
.digest-collapsed .digest-cluster[data-cluster="down"] { display: none; }
.digest-toggle {
  cursor: pointer;
  color: var(--fg4);
  font-size: 12px;
  margin-left: 4px;
  user-select: none;
}
.digest-toggle:hover { color: var(--fg2); }
table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
}
thead tr {
  background: var(--bg-sunken);
  border-bottom: 1px solid var(--border);
}
thead th {
  padding: 10px 16px;
  text-align: left;
  color: var(--fg4);
  font-size: 10px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.10em;
  cursor: pointer;
  user-select: none;
  white-space: nowrap;
}
thead th:hover { color: var(--fg2); }
thead th.sort-asc::after  { content: " ▲"; font-size: 0.75em; }
thead th.sort-desc::after { content: " ▼"; font-size: 0.75em; }
tbody tr { border-bottom: 1px dashed var(--border-soft); }
tbody tr:last-child { border-bottom: none; }
tbody td {
  padding: 11px 16px;
  vertical-align: middle;
  color: var(--fg2);
}
tbody td:nth-child(n+4) {
  font-family: var(--font-mono);
  font-size: 12px;
}
.rank-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 26px;
  height: 26px;
  border-radius: 50%;
  background: var(--bg-sunken);
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 12px;
  color: var(--fg3);
}
.rank-badge.top3 {
  background: var(--green-100);
  color: var(--green-700);
}
.arrow.up   { color: var(--up);   font-size: 11px; }
.arrow.down { color: var(--down); font-size: 11px; }
.tag-region {
  display: inline-block;
  font-size: 10px;
  font-weight: 500;
  padding: 2px 8px;
  border-radius: var(--radius-pill);
  background: var(--beige-200);
  color: var(--fg3);
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

/* Trajectory badges */
.traj-badge {
  display: inline-block;
  font-weight: 600;
  font-size: 0.82em;
  letter-spacing: 0.02em;
  padding: 2px 7px;
  border-radius: 4px;
  font-family: var(--font-mono);
}
.traj-badge.traj-strong_up   { color: var(--up); background: color-mix(in srgb, var(--up) 15%, transparent); }
.traj-badge.traj-up          { color: var(--up); background: color-mix(in srgb, var(--up) 8%, transparent); }
.traj-badge.traj-flat        { color: var(--fg4); background: color-mix(in srgb, var(--fg4) 10%, transparent); }
.traj-badge.traj-down        { color: var(--down); background: color-mix(in srgb, var(--down) 8%, transparent); }
.traj-badge.traj-strong_down { color: var(--down); background: color-mix(in srgb, var(--down) 15%, transparent); }

/* =========================================================
   Plotly chart containers
   ========================================================= */
.chart-container {
  background: var(--bg-raised);
  border: 1px solid var(--border-soft);
  border-radius: var(--radius-lg);
  overflow: hidden;
  min-height: 420px;
  box-shadow: var(--shadow-xs);
}

/* =========================================================
   Drill-down panel
   ========================================================= */
.drilldown-controls {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
  flex-wrap: wrap;
}
.drilldown-controls label {
  color: var(--fg4);
  font-size: 10px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.10em;
}
select.sector-select {
  background: var(--bg-raised);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  color: var(--fg1);
  font-family: var(--font-body);
  font-size: 13px;
  padding: 7px 12px;
  cursor: pointer;
  min-width: 220px;
  outline: none;
  transition: border-color var(--duration-fast) var(--ease-standard);
}
select.sector-select:focus {
  border-color: var(--green-400);
  box-shadow: 0 0 0 3px rgba(143,167,122,0.2);
}

/* Tab interpretation guides (compact ⓘ variant) */
.utility-row {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 12px;
  padding: 6px 0 0;
}
.tab-guide {
  border: none;
  background: none;
  margin: 0;
  padding: 0;
  font-size: 0.8rem;
}
.tab-guide summary {
  padding: 0;
  cursor: pointer;
  color: var(--fg4);
  font-weight: 500;
  font-size: 12px;
  list-style: none;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  user-select: none;
}
.tab-guide summary::before {
  content: "ⓘ";
  font-size: 1em;
}
.tab-guide summary:hover { color: var(--fg2); }
.tab-guide[open] summary { color: var(--fg2); }
.tab-guide[open] summary::before {
  content: "ⓘ";
}
.tab-guide-body {
  padding: 12px 0 8px;
  color: var(--fg2);
  line-height: 1.65;
  font-size: 0.875rem;
}
.tab-guide-body h4 {
  margin: 12px 0 4px;
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--fg4);
}
.tab-guide-body ul {
  margin: 4px 0 0 0;
  padding-left: 18px;
}
.tab-guide-body li { margin-bottom: 3px; }
.signal-hi { color: var(--up); font-weight: 600; }
.signal-lo { color: var(--down); font-weight: 600; }

/* =========================================================
   Rank settings popover (sentiment control)
   ========================================================= */
.rank-settings {
  position: relative;
  border: none;
  background: none;
  margin: 0;
  padding: 0;
}
.rank-settings summary {
  cursor: pointer;
  color: var(--fg4);
  font-size: 12px;
  font-weight: 500;
  list-style: none;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  user-select: none;
}
.rank-settings summary:hover { color: var(--fg2); }
.rank-settings .sentiment-control {
  position: absolute;
  right: 0;
  top: calc(100% + 6px);
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  padding: 12px 16px;
  z-index: 100;
  white-space: nowrap;
  min-width: 260px;
}

/* =========================================================
   Responsive
   ========================================================= */
@media (max-width: 600px) {
  .command-bar { padding: 10px 16px; }
  .card { margin: 12px 12px 16px; }
  .card > .tab-panel { padding: 14px 16px; }
  .card > .tabs { padding: 0 8px; }
  .site-footer { padding: 14px 16px; }
}
@media (max-width: 420px) {
  .scan-meta { display: none; }
}

/* =========================================================
   Leaderboard row breakdown
   ========================================================= */
.leaderboard-row { cursor: pointer; }
.leaderboard-row:hover { background: rgba(143,167,122,0.06); }
.chevron {
  font-size: 0.6em;
  color: var(--fg4);
  margin-left: 5px;
  display: inline-block;
  transition: transform var(--duration-fast) var(--ease-standard);
}
.breakdown-row { display: none; }
.breakdown-row.open { display: table-row; }
.breakdown-inner {
  padding: 16px 20px;
  background: var(--bg-sunken);
  border-top: 1px solid var(--border-soft);
}
.breakdown-grid {
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: 24px;
  align-items: start;
}
@media (max-width: 700px) { .breakdown-grid { grid-template-columns: 1fr; } }

/* Score tree */
.score-tree {
  font-family: var(--font-mono);
  font-size: 12px;
  line-height: 2;
}
.st-row { display: flex; align-items: baseline; gap: 4px; }
.st-top .st-label { font-weight: 600; color: var(--fg1); }
.st-top .st-val   { font-weight: 600; color: var(--brand-strong); }
.st-conn  { color: var(--fg4); white-space: pre; min-width: 2.5em; }
.st-label { color: var(--fg3); }
.st-wt    { color: var(--fg4); font-size: 0.9em; }
.st-val   { color: var(--fg2); margin-left: auto; min-width: 48px; text-align: right; }
.st-meta  { color: var(--fg4); font-size: 0.85em; margin-left: 4px; }
.bd-footer {
  margin-top: 10px;
  font-size: 11px;
  color: var(--fg4);
  border-top: 1px dashed var(--border-soft);
  padding-top: 8px;
  font-family: var(--font-mono);
}

/* Signal tables */
.sig-section { margin-bottom: 12px; }
.sig-title {
  font-size: 10px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.10em;
  color: var(--fg4);
  margin-bottom: 5px;
}
.sig-table { border-collapse: collapse; width: 100%; font-size: 12px; }
.sig-table td { padding: 3px 6px; vertical-align: middle; }
.sig-label { color: var(--fg3); white-space: nowrap; }
.sig-raw   { color: var(--fg2); font-family: var(--font-mono); text-align: right; min-width: 54px; }
.sig-bar   { padding: 0 8px; }
.sig-z     { color: var(--fg4); font-family: var(--font-mono); text-align: right; min-width: 46px; }
.z-bar-wrap {
  display: inline-block;
  width: 60px; height: 6px;
  background: var(--beige-300);
  border-radius: var(--radius-pill);
  vertical-align: middle;
}
.z-bar {
  display: inline-block;
  height: 6px;
  border-radius: var(--radius-pill);
}
.sig-chip   { font-size: 11px; }
.sig-chip.bull { color: var(--green-600); }
.sig-chip.bear { color: var(--terra-500); }
.sig-chip.neut { color: var(--fg4); }
/* Signal tooltip */
.sig-tip {
  border-bottom: 1px dashed var(--fg4);
  cursor: help;
  position: relative;
}
.sig-tip::after {
  content: attr(data-tip);
  display: none;
  position: absolute;
  left: 0; top: calc(100% + 6px);
  min-width: 220px; max-width: 320px;
  background: var(--bg-raised);
  border: 1px solid var(--border);
  color: var(--fg2);
  font-size: 0.78rem;
  font-family: var(--font-body);
  line-height: 1.55;
  padding: 7px 11px;
  border-radius: var(--radius-md);
  box-shadow: 0 3px 10px rgba(0,0,0,0.12);
  white-space: normal;
  z-index: 200;
  pointer-events: none;
}
.sig-tip:hover::after, .sig-tip:focus::after { display: block; }
/* Setup badges (entry / exit) */
.setup-badge {
  display: inline-block;
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.03em;
  padding: 1px 6px;
  border-radius: var(--radius-pill);
  margin-left: 6px;
  vertical-align: middle;
}
.setup-badge.entry {
  color: var(--up);
  background: color-mix(in srgb, var(--up) 12%, transparent);
  border: 1px solid color-mix(in srgb, var(--up) 30%, transparent);
}
.setup-badge.exit {
  color: var(--down);
  background: color-mix(in srgb, var(--down) 12%, transparent);
  border: 1px solid color-mix(in srgb, var(--down) 30%, transparent);
}
.sig-info {
  font-size: 11px;
  color: var(--fg4);
  margin-top: 8px;
  border-top: 1px dashed var(--border-soft);
  padding-top: 6px;
}
.info-lbl { font-weight: 500; }

/* Instruments table */
.bd-instruments {
  margin-top: 14px;
  border-top: 1px dashed var(--border-soft);
  padding-top: 10px;
}
.etf-table { border-collapse: collapse; width: 100%; font-size: 12px; }
.etf-table th {
  font-size: 10px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--fg4);
  border-bottom: 1px solid var(--border-soft);
  padding: 2px 8px 5px;
  text-align: left;
}
.etf-table td { padding: 4px 8px; vertical-align: middle; }
.etf-ticker { font-family: var(--font-mono); font-weight: 600; color: var(--fg2); white-space: nowrap; }
.etf-name   { color: var(--fg3); }
.etf-ter    { font-family: var(--font-mono); color: var(--fg4); text-align: right; white-space: nowrap; }
.etf-isin   { font-family: var(--font-mono); font-size: 11px; color: var(--fg4); }
.etf-match  { font-size: 11px; text-transform: capitalize; white-space: nowrap; }
.etf-match-exact   { color: var(--up); }
.etf-match-close   { color: var(--fg3); }
.etf-match-partial { color: var(--fg4); font-style: italic; }
.etf-link a { color: var(--brand-strong); text-decoration: none; }
.etf-link a:hover { color: var(--brand-strong); }

/* =========================================================
   Sentiment toggle control
   ========================================================= */
.sentiment-control { display:flex; align-items:center; gap:16px; margin:8px 0 12px; font-size:0.9em; color:#3E392B; }
.sentiment-control input[type=number] { width:52px; }
.sentiment-control .sw-weight[data-disabled="true"] { opacity:0.45; }
.tab-note { font-size:0.8em; color:#8C8370; margin:0 0 8px; }

/* --- Sentiment: seasonal + rising queries --- */
.seasonal-hi { color: var(--up); }
.seasonal-lo { color: var(--down); }
.has-rising { cursor: pointer; }
.has-rising:hover { background: var(--bg-raised); }
.has-rising:focus-visible { outline: 2px solid var(--brand-strong); outline-offset: -2px; }
.rising-toggle {
  width: 1.2em;
  text-align: center;
  color: var(--fg4);
  font-size: 0.7em;
  transition: transform 0.15s;
  user-select: none;
}
.has-rising.open .rising-toggle { transform: rotate(90deg); }
.rising-panel td { padding: 0 !important; border-bottom: none !important; }
.rising-inner {
  padding: 8px 16px 12px 36px;
  background: var(--bg-sunken);
  border-bottom: 1px solid var(--border-soft);
}
.rising-inner strong { font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--fg4); }
.rising-table {
  width: auto;
  margin-top: 4px;
  font-size: 12px;
}
.rising-table thead th {
  padding: 4px 12px;
  font-size: 9px;
  cursor: default;
}
.rising-table tbody td { padding: 4px 12px; }

/* =========================================================
   Site footer
   ========================================================= */
.site-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 28px;
  margin-top: 8px;
  border-top: 1px solid var(--border-soft);
  font-size: 11px;
  color: var(--fg4);
}
.site-footer a {
  color: var(--fg3);
  text-decoration: none;
}
.site-footer a:hover { color: var(--brand-strong); }

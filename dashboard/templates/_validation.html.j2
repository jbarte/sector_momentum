{# Forward-return validation & holding-period stats panels #}
{% if validation_min_scans_met %}
<h3 style="margin:22px 0 6px;font-family:var(--font-display);font-size:15px;color:var(--fg1)" data-i18n="val_fwd_title">Do the rankings predict returns?</h3>
<p class="tab-note" data-i18n="val_fwd_desc">Excess return of top-5 sectors vs region benchmark.</p>
<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th data-i18n="val_region">Region</th>
        <th data-i18n="val_horizon">Horizon</th>
        <th data-i18n="val_obs">Obs</th>
        <th data-i18n="val_hit_rate">Hit rate</th>
        <th data-i18n="val_mean">Mean excess</th>
        <th data-i18n="val_median">Median excess</th>
      </tr>
    </thead>
    <tbody>
      {% for row in validation_fwd_returns %}
      <tr>
        <td>{{ row.region }}</td>
        <td>{{ row.horizon }}</td>
        <td>{{ row.obs }}</td>
        {% if row.hit_rate is not none %}
        <td class="{% if row.hit_rate > 0.5 %}signal-hi{% elif row.hit_rate < 0.5 %}signal-lo{% endif %}">{{ "%.0f%%"|format(row.hit_rate * 100) }}</td>
        <td class="{% if row.mean_excess > 0 %}signal-hi{% elif row.mean_excess < 0 %}signal-lo{% endif %}">{{ "%+.2f%%"|format(row.mean_excess * 100) }}</td>
        <td class="{% if row.median_excess > 0 %}signal-hi{% elif row.median_excess < 0 %}signal-lo{% endif %}">{{ "%+.2f%%"|format(row.median_excess * 100) }}</td>
        {% else %}
        <td>—</td><td>—</td><td>—</td>
        {% endif %}
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<h3 style="margin:22px 0 6px;font-family:var(--font-display);font-size:15px;color:var(--fg1)" data-i18n="val_hold_title">How long do top-5 positions last?</h3>
<p class="tab-note" data-i18n="val_hold_desc">Duration of contiguous top-5 rank streaks (in scans).</p>
<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th data-i18n="val_region">Region</th>
        <th data-i18n="val_hold_runs">Runs</th>
        <th data-i18n="val_hold_median">Median</th>
        <th data-i18n="val_hold_mean">Mean</th>
        <th data-i18n="val_min">Min</th>
        <th data-i18n="val_max">Max</th>
      </tr>
    </thead>
    <tbody>
      {% for row in validation_holding %}
      <tr>
        <td>{{ row.region }}</td>
        <td>{{ row.runs }}{% if row.ongoing %} <span style="color:var(--fg4)">({{ row.ongoing }} <span data-i18n="val_ongoing">ongoing</span>)</span>{% endif %}</td>
        {% if row.median is not none %}
        <td>{{ row.median }}</td>
        <td>{{ row.mean }}</td>
        <td>{{ row.min }}</td>
        <td>{{ row.max }}</td>
        {% else %}
        <td>—</td><td>—</td><td>—</td><td>—</td>
        {% endif %}
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endif %}

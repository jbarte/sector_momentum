/* =========================================================
   Command bar
   ========================================================= */
.command-bar {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 28px;
  flex-wrap: wrap;
}
.command-bar h1 {
  font-family: var(--font-display);
  font-size: 16px;
  font-weight: 600;
  color: var(--fg1);
  letter-spacing: -0.02em;
  line-height: 1;
  white-space: nowrap;
}
.meta-cluster {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-left: auto;
}
.scan-meta {
  font-size: 11px;
  color: var(--fg4);
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
}
.lang-toggle {
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--fg3);
  background: transparent;
  border: 1px solid var(--border);
  border-radius: var(--radius-pill);
  padding: 3px 12px;
  cursor: pointer;
  transition: color var(--duration-fast) var(--ease-standard),
              border-color var(--duration-fast) var(--ease-standard);
}
.lang-toggle:hover { color: var(--brand-strong); border-color: var(--brand-strong); }
.auth-root { position: relative; display: inline-flex; align-items: center; gap: 8px; }
.auth-root .lang-toggle { white-space: nowrap; }
/* Email form opens as a dropdown card anchored under the Sign in button, so
   the input/send/status group reads as one unit instead of reflowing the
   command bar. Same surface treatment as the .card shell. */
.auth-form {
  position: absolute;
  top: calc(100% + 10px);
  right: 0;
  z-index: 40;
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 14px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  box-shadow: var(--shadow-card);
}
.auth-form[hidden] { display: none; }
.auth-form input[type="email"] {
  background: var(--bg-raised);
  color: var(--fg1);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 4px 8px;
  font: inherit;
  font-size: 0.8rem;
  width: 14em;
}
.auth-status { color: var(--fg4); font-size: 0.75rem; max-width: 16em; }
.auth-status:empty { display: none; }

/* =========================================================
   Chips (macro indicators in command bar)
   ========================================================= */
.chip {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 500;
  padding: 2px 8px;
  border-radius: var(--radius-sm);
  white-space: nowrap;
  cursor: default;
  font-variant-numeric: tabular-nums;
}
.chip-up   { background: color-mix(in srgb, var(--up) 12%, transparent); color: var(--up); }
.chip-down { background: color-mix(in srgb, var(--down) 12%, transparent); color: var(--down); }
.chip-calm      { background: color-mix(in srgb, var(--up) 12%, transparent); color: var(--up); }
.chip-elevated  { background: color-mix(in srgb, var(--fg1) 8%, transparent); color: var(--fg1); }
.chip-stressed  { background: color-mix(in srgb, var(--down) 12%, transparent); color: var(--down); }

/* =========================================================
   Card shell
   ========================================================= */
.card {
  background: var(--surface);
  border-radius: 10px;
  box-shadow: var(--shadow-card);
  margin: 16px 28px 24px;
  overflow: hidden;
}
.card > .tabs {
  background: var(--surface);
  border-bottom: 1px solid var(--border-soft);
  padding: 0 20px;
  border-radius: 10px 10px 0 0;
}
.card > .tab-panel { padding: 20px 24px; }

/* =========================================================
   Segment toggle (Sectors ⇄ Sentiment) — top-level page switcher,
   distinct from the sector tab bar below it.
   ========================================================= */
.segment-toggle {
  display: inline-flex;
  background: var(--beige-200);
  border-radius: var(--radius-pill);
  padding: 3px;
  gap: 2px;
}
.segment-btn {
  display: inline-flex;
  align-items: center;
  padding: 5px 14px;
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: 500;
  color: var(--fg3);
  text-decoration: none;
  border-radius: var(--radius-pill);
  white-space: nowrap;
  cursor: pointer;
  /* Reset <button> UA chrome so button-based toggles match <a>/<span> ones. */
  border: none;
  background: transparent;
  -webkit-appearance: none;
  appearance: none;
  transition: color var(--duration-fast) var(--ease-standard),
              background var(--duration-fast) var(--ease-standard);
}
.segment-btn:hover { color: var(--fg1); }
.segment-btn.active {
  background: var(--bg-raised);
  color: var(--brand-strong);
  font-weight: 600;
  box-shadow: var(--shadow-xs);
  cursor: default;
}

/* =========================================================
   Tab bar
   ========================================================= */
.tabs {
  display: flex;
  background: var(--bg-raised);
  border-bottom: 1px solid var(--border);
  overflow-x: auto;
  padding: 0 24px;
}
.tab-btn {
  text-decoration: none;
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  color: var(--fg4);
  cursor: pointer;
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 500;
  padding: 11px 16px;
  white-space: nowrap;
  transition: color var(--duration-fast) var(--ease-standard),
              border-color var(--duration-fast) var(--ease-standard);
}
.tab-btn:hover { color: var(--fg2); }
.tab-btn.active {
  color: var(--brand-strong);
  border-bottom-color: var(--brand-strong);
}

/* =========================================================
   Tab content panels
   ========================================================= */
.tab-panel { display: none; padding: 24px 28px; }
.tab-panel.active { display: block; }

/* =========================================================
   Site footer
   ========================================================= */
.site-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 28px;
  margin-top: 8px;
  border-top: 1px solid var(--border-soft);
  font-size: 11px;
  color: var(--fg4);
}
.site-footer a {
  color: var(--fg3);
  text-decoration: none;
}
.site-footer a:hover { color: var(--brand-strong); }

/* =========================================================
   Content-gating: lag-notice banner
   ========================================================= */
.lag-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 12px;
  padding: 10px 16px;
  margin: 0 0 12px;
  background: var(--bg-raised);
  border: 1px solid var(--border);
  border-radius: 10px;
  font-size: 0.85rem;
  color: var(--fg2);
}
.lag-banner[hidden] { display: none; }
.lag-banner-text strong { color: var(--fg1); }
.lag-banner-btn {
  border: 1px solid var(--brand-strong);
  color: var(--brand-strong);
  background: transparent;
  border-radius: var(--radius-sm);
  padding: 4px 12px;
  font: inherit;
  font-size: 0.8rem;
  cursor: pointer;
}
.lag-banner-btn:hover { background: var(--brand-strong); color: var(--surface); }

/* =========================================================
   Content-gating: landing modal
   ========================================================= */
.gate-modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  background: rgba(0, 0, 0, 0.45);
  backdrop-filter: blur(3px);
}
.gate-modal-overlay[hidden] { display: none; }
.gate-modal {
  max-width: 420px;
  width: 100%;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 14px;
  box-shadow: var(--shadow-card);
  padding: 28px 26px;
  text-align: center;
}
.gate-modal h2 { margin: 0 0 8px; font-size: 1.3rem; color: var(--fg1); }
.gate-modal p { margin: 0 0 18px; color: var(--fg2); font-size: 0.9rem; }
/* Inside the modal the form is static (not the header dropdown), so reset the
   absolute positioning the .auth-form rule applies in the command bar. */
.gate-modal-form {
  position: static;
  justify-content: center;
  flex-wrap: wrap;
  box-shadow: none;
  padding: 0;
  border: none;
  background: transparent;
  margin-bottom: 14px;
}
.gate-modal-continue {
  border: none;
  background: transparent;
  color: var(--fg4);
  font: inherit;
  font-size: 0.85rem;
  text-decoration: underline;
  cursor: pointer;
}
.gate-modal-continue:hover { color: var(--fg2); }

/* =========================================================
   Methodology reference modal
   ========================================================= */
.methodology-overlay {
  position: fixed;
  inset: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  background: rgba(0, 0, 0, 0.45);
  backdrop-filter: blur(3px);
}
.methodology-overlay[hidden] { display: none; }
.methodology-modal {
  position: relative;
  max-width: 640px;
  width: 100%;
  max-height: 85vh;
  overflow-y: auto;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 14px;
  box-shadow: var(--shadow-card);
  padding: 28px 30px;
  text-align: left;
}
.methodology-modal h2 { margin: 0 0 14px; font-size: 1.3rem; color: var(--fg1); }
.methodology-modal h3 { margin: 20px 0 6px; font-size: 1rem; color: var(--fg1); }
.methodology-body p,
.methodology-body li { color: var(--fg2); font-size: 0.9rem; line-height: 1.55; }
.methodology-body ul { margin: 6px 0; padding-left: 20px; }
.methodology-body code { font-size: 0.85em; color: var(--fg1); }
.methodology-close {
  position: absolute;
  top: 12px;
  right: 14px;
  border: none;
  background: transparent;
  color: var(--fg4);
  font-size: 1.4rem;
  line-height: 1;
  cursor: pointer;
}
.methodology-close:hover { color: var(--fg1); }
/* Footer trigger styled as a link button */
.footer-link {
  border: none;
  background: transparent;
  color: inherit;
  font: inherit;
  text-decoration: underline;
  cursor: pointer;
  padding: 0;
}

/* =========================================================
   Modal illustration — rotation arcs (gate + methodology)
   ========================================================= */
.modal-illo-band {
  overflow: hidden;
  background: linear-gradient(160deg, #F5F0E6 0%, #EDE6D6 100%);
}
.methodology-modal .modal-illo-band { margin: -28px -30px 18px; border-radius: 14px 14px 0 0; }
.gate-modal .modal-illo-band        { margin: -28px -26px 18px; border-radius: 14px 14px 0 0; }
.modal-illo { display: block; width: 100%; height: 120px; }
.gate-modal .modal-illo { height: 104px; }
/* keep the methodology close button above the band */
.methodology-close { z-index: 1; }

/* Reveal — auto-fires when the modal's display flips from none to shown. */
.modal-illo .arc {
  stroke-dasharray: 900; stroke-dashoffset: 900;
  animation: illo-draw 1s var(--ease-standard) forwards;
}
.modal-illo .a1 { animation-delay: .05s; }
.modal-illo .a2 { animation-delay: .18s; }
.modal-illo .a3 { animation-delay: .31s; }
.modal-illo .a4 { animation-delay: .44s; }
.modal-illo .sweep {
  opacity: 0;
  animation: illo-fade .7s ease .55s forwards, illo-flow 3s linear 1.4s infinite;
}
.modal-illo .dot, .modal-illo .halo {
  opacity: 0; transform: scale(.4); transform-origin: center; transform-box: fill-box;
  animation: illo-pop .5s var(--ease-standard) forwards;
}
.modal-illo .d1 { animation-delay: .60s; }
.modal-illo .d2 { animation-delay: .72s; }
.modal-illo .d3 { animation-delay: .84s; }
.modal-illo .d4 { animation-delay: .98s; }
.modal-illo .d5 { animation-delay: 1.10s; }
/* leader halo: reveal, then slow ambient breathe */
.modal-illo .halo {
  animation: illo-pop .5s var(--ease-standard) .96s forwards,
             illo-breathe 3.8s ease-in-out 1.8s infinite;
}

@keyframes illo-draw    { to { stroke-dashoffset: 0; } }
@keyframes illo-fade    { to { opacity: .5; } }
@keyframes illo-pop     { to { opacity: 1; transform: scale(1); } }
@keyframes illo-breathe { 0%, 100% { transform: scale(1); opacity: .45; } 50% { transform: scale(1.14); opacity: .18; } }
@keyframes illo-flow    { to { stroke-dashoffset: -16; } }

@media (prefers-reduced-motion: reduce) {
  .modal-illo .arc { stroke-dashoffset: 0; animation: none; }
  .modal-illo .sweep, .modal-illo .dot, .modal-illo .halo {
    opacity: 1; transform: none; animation: none;
  }
  .modal-illo .sweep { opacity: .5; }
  .modal-illo .halo  { opacity: .45; }
}

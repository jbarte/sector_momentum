/* Tab interpretation guides (compact ⓘ variant) */
.utility-row {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 12px;
  padding: 6px 0 0;
}
.tab-guide {
  border: none;
  background: none;
  margin: 0;
  padding: 0;
  font-size: 0.8rem;
}
.tab-guide summary {
  padding: 0;
  cursor: pointer;
  color: var(--fg4);
  font-weight: 500;
  font-size: 12px;
  list-style: none;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  user-select: none;
}
.tab-guide summary::before {
  content: "ⓘ";
  font-size: 1em;
}
.tab-guide summary:hover { color: var(--fg2); }
.tab-guide[open] summary { color: var(--fg2); }
.tab-guide[open] summary::before {
  content: "ⓘ";
}
.tab-guide-body {
  padding: 12px 0 8px;
  color: var(--fg2);
  line-height: 1.65;
  font-size: 0.875rem;
}
.tab-guide-body h4 {
  margin: 12px 0 4px;
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--fg4);
}
.tab-guide-body ul {
  margin: 4px 0 0 0;
  padding-left: 18px;
}
.tab-guide-body li { margin-bottom: 3px; }
.signal-hi { color: var(--up); font-weight: 600; }
.signal-lo { color: var(--down); font-weight: 600; }

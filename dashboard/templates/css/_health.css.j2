.health-panel { margin: 1rem 0 0; padding: 0.5rem 1rem; font-size: 0.85rem; border-top: 1px solid var(--border, #ddd); color: var(--text-muted, #888); }
.health-panel summary { cursor: pointer; font-weight: 600; }
.health-grid { display: grid; gap: 0.3rem; margin-top: 0.5rem; }
.health-row { display: flex; gap: 0.5rem; }
.health-label { min-width: 5.5rem; font-weight: 600; }
.health-muted { opacity: 0.5; font-style: italic; }
.health-warn-dot { color: #e67e22; }
.badge-green { color: #27ae60; font-weight: 600; }
.badge-amber { color: #e67e22; font-weight: 600; }
.badge-red { color: #c0392b; font-weight: 600; }

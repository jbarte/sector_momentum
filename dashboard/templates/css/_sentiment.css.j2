/* =========================================================
   Rank settings popover (sentiment control)
   ========================================================= */
.rank-settings {
  position: relative;
  border: none;
  background: none;
  margin: 0;
  padding: 0;
}
.rank-settings summary {
  cursor: pointer;
  color: var(--fg4);
  font-size: 12px;
  font-weight: 500;
  list-style: none;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  user-select: none;
}
.rank-settings summary:hover { color: var(--fg2); }
.rank-settings .sentiment-control {
  position: absolute;
  right: 0;
  top: calc(100% + 6px);
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  padding: 12px 16px;
  z-index: 100;
  white-space: nowrap;
  min-width: 260px;
}
/* =========================================================
   Sentiment toggle control
   ========================================================= */
.sentiment-control { display:flex; align-items:center; gap:16px; margin:8px 0 12px; font-size:0.9em; color:#3E392B; }
.sentiment-control input[type=number] { width:52px; }
.sentiment-control .sw-weight[data-disabled="true"] { opacity:0.45; }
.tab-note { font-size:0.8em; color:#8C8370; margin:0 0 8px; }

/* --- Sentiment: seasonal + rising queries --- */
.seasonal-hi { color: var(--up); }
.seasonal-lo { color: var(--down); }
.has-rising { cursor: pointer; }
.has-rising:hover { background: var(--bg-raised); }
.has-rising:focus-visible { outline: 2px solid var(--brand-strong); outline-offset: -2px; }
.rising-toggle {
  width: 1.2em;
  text-align: center;
  color: var(--fg4);
  font-size: 0.7em;
  transition: transform 0.15s;
  user-select: none;
}
.has-rising.open .rising-toggle { transform: rotate(90deg); }
.rising-panel td { padding: 0 !important; border-bottom: none !important; }
.rising-inner {
  padding: 8px 16px 12px 36px;
  background: var(--bg-sunken);
  border-bottom: 1px solid var(--border-soft);
}
.rising-inner strong { font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--fg4); }
.rising-table {
  width: auto;
  margin-top: 4px;
  font-size: 12px;
}
.rising-table thead th {
  padding: 4px 12px;
  font-size: 9px;
  cursor: default;
}
.rising-table tbody td { padding: 4px 12px; }

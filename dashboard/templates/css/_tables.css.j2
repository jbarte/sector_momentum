/* =========================================================
   Leaderboard table
   ========================================================= */
.table-wrap {
  overflow-x: auto;
  border-radius: var(--radius-lg);
  border: 1px solid var(--border-soft);
  background: var(--bg-raised);
  box-shadow: var(--shadow-xs);
}
.scan-index { margin-bottom: 20px; }
.scan-index .active-scan { background: var(--green-100); }
.showing-badge { color: var(--green-700); font-weight: 600; font-size: 0.8em; white-space: nowrap; }
.scan-index tr[data-scan-id] { cursor: pointer; }
.scan-index tr[data-scan-id]:not(.active-scan):hover { background: var(--bg-sunken); }
.scan-index tr[data-scan-id]:focus-visible { outline: 2px solid var(--brand-strong); outline-offset: -2px; }
#scan-history-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 16px;
  margin-bottom: 8px;
  background: var(--bg-raised);
  border-left: 3px solid var(--brand-strong);
  border-radius: var(--radius-sm);
  font-size: 13px;
  color: var(--fg3);
}
#scan-history-banner a {
  color: var(--brand-strong);
  font-weight: 500;
  text-decoration: none;
}
#scan-history-banner a:hover { text-decoration: underline; }
#scan-digest-banner {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 6px 16px;
  padding: 8px 16px;
  margin-bottom: 8px;
  background: var(--bg-raised);
  border-left: 3px solid var(--brand-strong);
  border-radius: var(--radius-sm);
  font-size: 13px;
  color: var(--fg3);
}
.digest-cluster { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
.digest-chips { display: flex; gap: 8px; flex-wrap: wrap; }
.digest-chip { white-space: nowrap; }
.digest-collapsed .digest-cluster[data-cluster="up"],
.digest-collapsed .digest-cluster[data-cluster="down"] { display: none; }
.digest-toggle {
  cursor: pointer;
  color: var(--fg4);
  font-size: 12px;
  margin-left: 4px;
  user-select: none;
}
.digest-toggle:hover { color: var(--fg2); }
table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
}
thead tr {
  background: var(--bg-sunken);
  border-bottom: 1px solid var(--border);
}
thead th {
  padding: 10px 16px;
  text-align: left;
  color: var(--fg4);
  font-size: 10px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.10em;
  cursor: pointer;
  user-select: none;
  white-space: nowrap;
}
thead th:hover { color: var(--fg2); }
thead th.sort-asc::after  { content: " ▲"; font-size: 0.75em; }
thead th.sort-desc::after { content: " ▼"; font-size: 0.75em; }
tbody tr { border-bottom: 1px dashed var(--border-soft); }
tbody tr:last-child { border-bottom: none; }
tbody td {
  padding: 11px 16px;
  vertical-align: middle;
  color: var(--fg2);
}
tbody td:nth-child(n+4) {
  font-family: var(--font-mono);
  font-size: 12px;
}
.rank-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 26px;
  height: 26px;
  border-radius: 50%;
  background: var(--bg-sunken);
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 12px;
  color: var(--fg3);
}
.rank-badge.top3 {
  background: var(--green-100);
  color: var(--green-700);
}
.arrow.up   { color: var(--up);   font-size: 11px; }
.arrow.down { color: var(--down); font-size: 11px; }
.tag-region {
  display: inline-block;
  font-size: 10px;
  font-weight: 500;
  padding: 2px 8px;
  border-radius: var(--radius-pill);
  background: var(--beige-200);
  color: var(--fg3);
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

/* Trajectory badges */
.traj-badge {
  display: inline-block;
  font-weight: 600;
  font-size: 0.82em;
  letter-spacing: 0.02em;
  padding: 2px 7px;
  border-radius: 4px;
  font-family: var(--font-mono);
}
.traj-badge.traj-strong_up   { color: var(--up); background: color-mix(in srgb, var(--up) 15%, transparent); }
.traj-badge.traj-up          { color: var(--up); background: color-mix(in srgb, var(--up) 8%, transparent); }
.traj-badge.traj-flat        { color: var(--fg4); background: color-mix(in srgb, var(--fg4) 10%, transparent); }
.traj-badge.traj-down        { color: var(--down); background: color-mix(in srgb, var(--down) 8%, transparent); }
.traj-badge.traj-strong_down { color: var(--down); background: color-mix(in srgb, var(--down) 15%, transparent); }
/* =========================================================
   Leaderboard row breakdown
   ========================================================= */
.leaderboard-row { cursor: pointer; }
.leaderboard-row:hover { background: rgba(143,167,122,0.06); }
.chevron {
  font-size: 0.6em;
  color: var(--fg4);
  margin-left: 5px;
  display: inline-block;
  transition: transform var(--duration-fast) var(--ease-standard);
}
.breakdown-row { display: none; }
.breakdown-row.open { display: table-row; }
.breakdown-inner {
  padding: 16px 20px;
  background: var(--bg-sunken);
  border-top: 1px solid var(--border-soft);
}
.breakdown-grid {
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: 24px;
  align-items: start;
}
@media (max-width: 700px) { .breakdown-grid { grid-template-columns: 1fr; } }

/* Score tree */
.score-tree {
  font-family: var(--font-mono);
  font-size: 12px;
  line-height: 2;
}
.st-row { display: flex; align-items: baseline; gap: 4px; }
.st-top .st-label { font-weight: 600; color: var(--fg1); }
.st-top .st-val   { font-weight: 600; color: var(--brand-strong); }
.st-conn  { color: var(--fg4); white-space: pre; min-width: 2.5em; }
.st-label { color: var(--fg3); }
.st-wt    { color: var(--fg4); font-size: 0.9em; }
.st-val   { color: var(--fg2); margin-left: auto; min-width: 48px; text-align: right; }
.st-meta  { color: var(--fg4); font-size: 0.85em; margin-left: 4px; }
.bd-footer {
  margin-top: 10px;
  font-size: 11px;
  color: var(--fg4);
  border-top: 1px dashed var(--border-soft);
  padding-top: 8px;
  font-family: var(--font-mono);
}

/* Signal tables */
.sig-section { margin-bottom: 12px; }
.sig-title {
  font-size: 10px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.10em;
  color: var(--fg4);
  margin-bottom: 5px;
}
.sig-table { border-collapse: collapse; width: 100%; font-size: 12px; }
.sig-table td { padding: 3px 6px; vertical-align: middle; }
.sig-label { color: var(--fg3); white-space: nowrap; }
.sig-raw   { color: var(--fg2); font-family: var(--font-mono); text-align: right; min-width: 54px; }
.sig-bar   { padding: 0 8px; }
.sig-z     { color: var(--fg4); font-family: var(--font-mono); text-align: right; min-width: 46px; }
.z-bar-wrap {
  display: inline-block;
  width: 60px; height: 6px;
  background: var(--beige-300);
  border-radius: var(--radius-pill);
  vertical-align: middle;
}
.z-bar {
  display: inline-block;
  height: 6px;
  border-radius: var(--radius-pill);
}
.sig-chip   { font-size: 11px; }
.sig-chip.bull { color: var(--green-600); }
.sig-chip.bear { color: var(--terra-500); }
.sig-chip.neut { color: var(--fg4); }
/* Signal tooltip */
.sig-tip {
  border-bottom: 1px dashed var(--fg4);
  cursor: help;
  position: relative;
}
.sig-tip::after {
  content: attr(data-tip);
  display: none;
  position: absolute;
  left: 0; top: calc(100% + 6px);
  min-width: 220px; max-width: 320px;
  background: var(--bg-raised);
  border: 1px solid var(--border);
  color: var(--fg2);
  font-size: 0.78rem;
  font-family: var(--font-body);
  line-height: 1.55;
  padding: 7px 11px;
  border-radius: var(--radius-md);
  box-shadow: 0 3px 10px rgba(0,0,0,0.12);
  white-space: normal;
  z-index: 200;
  pointer-events: none;
}
.sig-tip:hover::after, .sig-tip:focus::after { display: block; }
/* Setup badges (entry / exit) */
.setup-badge {
  display: inline-block;
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.03em;
  padding: 1px 6px;
  border-radius: var(--radius-pill);
  margin-left: 6px;
  vertical-align: middle;
}
.setup-badge.entry {
  color: var(--up);
  background: color-mix(in srgb, var(--up) 12%, transparent);
  border: 1px solid color-mix(in srgb, var(--up) 30%, transparent);
}
.setup-badge.exit {
  color: var(--down);
  background: color-mix(in srgb, var(--down) 12%, transparent);
  border: 1px solid color-mix(in srgb, var(--down) 30%, transparent);
}
.sig-info {
  font-size: 11px;
  color: var(--fg4);
  margin-top: 8px;
  border-top: 1px dashed var(--border-soft);
  padding-top: 6px;
}
.info-lbl { font-weight: 500; }

/* Instruments table */
.bd-instruments {
  margin-top: 14px;
  border-top: 1px dashed var(--border-soft);
  padding-top: 10px;
}
.etf-table { border-collapse: collapse; width: 100%; font-size: 12px; }
.etf-table th {
  font-size: 10px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--fg4);
  border-bottom: 1px solid var(--border-soft);
  padding: 2px 8px 5px;
  text-align: left;
}
.etf-table td { padding: 4px 8px; vertical-align: middle; }
.etf-ticker { font-family: var(--font-mono); font-weight: 600; color: var(--fg2); white-space: nowrap; }
.etf-name   { color: var(--fg3); }
.etf-ter    { font-family: var(--font-mono); color: var(--fg4); text-align: right; white-space: nowrap; }
.etf-isin   { font-family: var(--font-mono); font-size: 11px; color: var(--fg4); }
.etf-match  { font-size: 11px; text-transform: capitalize; white-space: nowrap; }
.etf-match-exact   { color: var(--up); }
.etf-match-close   { color: var(--fg3); }
.etf-match-partial { color: var(--fg4); font-style: italic; }
.etf-link a { color: var(--brand-strong); text-decoration: none; }

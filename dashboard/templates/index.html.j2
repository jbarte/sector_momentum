<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Sector Momentum</title>
<script src="{{ plotly_bundle }}"></script>
<script src="assets/rescore.js"></script>
<style>
{% include "_style.html.j2" %}
</style>
</head>
<body>

<!-- Header -->
<header>
  <h1 data-i18n="title">Sector momentum</h1>
  <span class="scan-date"><span data-i18n="lastScan">Last scan:</span> {% if active_scan_id %}#{{ active_scan_id }} · {% endif %}{{ scan_date }}</span>
  <div class="segment-toggle" role="tablist" aria-label="Dashboard segment">
    <span class="segment-btn active" aria-current="page" data-i18n="segment_sectors">Sectors</span>
    <a class="segment-btn" href="themes.html" data-i18n="segment_themes">Themes</a>
    <a class="segment-btn" href="sentiment.html" data-i18n="segment_sentiment">Sentiment</a>
  </div>
  <span class="disclaimer" data-i18n="disclaimer">Analytical tooling, not investment advice.</span>
  <button id="lang-toggle" class="lang-toggle" type="button" onclick="toggleLang()" aria-label="Switch language">SV</button>
</header>

<!-- Tab bar -->
<nav class="tabs" role="tablist">
  <button class="tab-btn active" onclick="switchTab('leaderboard', this)" role="tab" data-i18n="tab_leaderboard">Leaderboard</button>
  <button class="tab-btn" onclick="switchTab('rrg', this)" role="tab" data-i18n="tab_rrg">RRG</button>
  <button class="tab-btn" onclick="switchTab('drilldown', this)" role="tab" data-i18n="tab_drilldown">Drill-down</button>
  <button class="tab-btn" onclick="switchTab('movers', this)" role="tab" data-i18n="tab_movers">Movers</button>
  <button class="tab-btn" onclick="switchTab('history', this)" role="tab" data-i18n="tab_history">History</button>
  <button class="tab-btn" onclick="switchTab('backtest', this)" role="tab" data-i18n="tab_backtest">Backtest</button>
  <button class="tab-btn" onclick="switchTab('guide', this)" role="tab" data-i18n="tab_guide">Guide</button>
</nav>

<!-- ============================================================
     Tab: Leaderboard
     ============================================================ -->
<section id="tab-leaderboard" class="tab-panel active">
  <details class="tab-guide">
    <summary data-i18n="guide_summary">How to read this tab</summary>
    <div class="tab-guide-body" data-i18n-html="guide_body_leaderboard">
      <p>Every sector is ranked by <strong>composite score</strong> — a cross-sectional z-score blending level momentum (how strong the sector is now) and change momentum (whether it's accelerating or decelerating). A score of <strong>0</strong> means average across all sectors; <strong>+1.0</strong> means one standard deviation above average.</p>
      <h4>Trend badge — the most actionable signal</h4>
      <p>Computed as the linear slope of rank over the last 3–5 scans. A falling rank number means the sector is climbing the leaderboard.</p>
      <ul>
        <li><span class="signal-hi">↑↑ Rising fast</span> — rank improving 1.5+ places per scan. Strong entry signal.</li>
        <li><span class="signal-hi">↑ Rising</span> — rank improving 0.3–1.5 places per scan. Emerging momentum.</li>
        <li>→ Flat — rank stable. Momentum is neither building nor unwinding.</li>
        <li><span class="signal-lo">↓ Falling</span> — rank deteriorating even if it is still high. Momentum is fading.</li>
        <li><span class="signal-lo">↓↓ Falling fast</span> — avoid or consider exiting.</li>
      </ul>
      <h4>Entry setup</h4>
      <p>Composite &gt; 0 with <span class="signal-hi">↑</span> or <span class="signal-hi">↑↑</span> trajectory and a positive Change score. Click any row to see the full signal breakdown.</p>
      <h4>Exit / avoid signal</h4>
      <p><span class="signal-lo">↓</span> or <span class="signal-lo">↓↓</span> trajectory even when rank is still high — the sector is topping. Rank Δ turning negative confirms the reversal.</p>
    </div>
  </details>
  <div id="sentiment-control" class="sentiment-control">
    <span class="sw-view">
      <span data-i18n="sectorView">Sector view:</span>
      <select id="sector-view-toggle">
        <option value="split" data-i18n="view_split">Region-split</option>
        <option value="composite" data-i18n="view_composite">Composite (US+EU)</option>
      </select>
    </span>
    <label>
      <input type="checkbox" id="sentiment-toggle"> <span data-i18n="includeSentiment">Include sentiment in ranking</span>
    </label>
    <span class="sw-weight">
      <span data-i18n="weight">Weight:</span> <input type="number" id="sentiment-weight" min="0" max="100" step="1" value="30" disabled>%
    </span>
  </div>
  <div class="table-wrap">
    <table id="leaderboard-table">
      <thead>
        <tr>
          <th onclick="sortTable(0)" data-col="0" data-i18n="col_rank">#</th>
          <th onclick="sortTable(1)" data-col="1" data-i18n="col_sector">Sector</th>
          <th onclick="sortTable(2)" data-col="2" data-i18n="col_region">Region</th>
          <th onclick="sortTable(3)" data-col="3" data-i18n="col_composite">Composite</th>
          <th onclick="sortTable(4)" data-col="4" data-i18n="col_level">Level</th>
          <th onclick="sortTable(5)" data-col="5" data-i18n="col_change">Change</th>
          <th onclick="sortTable(6)" data-col="6" data-i18n="col_data">Data</th>
          <th onclick="sortTable(7)" data-col="7" data-i18n="col_sentiment">Sentiment</th>
          <th onclick="sortTable(8)" data-col="8" data-i18n="col_rankdelta">Rank Δ</th>
          <th data-col="9" title="Rank slope over last 3–5 scans" data-i18n="col_trend">Trend</th>
        </tr>
      </thead>
      <tbody>
        {% for row in leaderboard_rows %}
        <tr class="leaderboard-row" data-view="split" data-sector-key="{{ row.key }}" data-sector-id="{{ row.sector_id }}" onclick="toggleBreakdown('{{ row.sector_id }}')">
          <td class="rank-cell">
            <span class="rank-badge{% if row.rank <= 3 %} top3{% endif %}">{{ row.rank }}</span>
            <span class="chevron" id="chev-{{ row.sector_id }}">▶</span>
          </td>
          <td>{{ row.sector }}{% if row.emerging %}<span class="emerging-badge">⬆ Emerging</span>{% endif %}</td>
          <td><span class="tag-region">{{ row.region }}</span></td>
          <td class="composite-cell">{{ row.composite }}</td>
          <td>{{ row.level_score }}</td>
          <td>{{ row.change_score }}</td>
          <td>{{ row.data_score }}</td>
          <td class="sentiment-cell">{{ row.sentiment_score }}</td>
          <td class="delta-cell">
            {% if row.arrow %}<span class="arrow {{ row.arrow_class }}">{{ row.arrow }}</span> {% endif %}{{ row.delta_rank }}
          </td>
          <td>
            <span class="traj-badge traj-{{ row.trajectory_state }}">{{ row.trajectory_label }}</span>
          </td>
        </tr>
        <tr class="breakdown-row" data-view="split" id="bd-{{ row.sector_id }}">
          <td colspan="10">{{ row.breakdown_html | safe }}</td>
        </tr>
        {% else %}
        <tr><td colspan="10" style="text-align:center;padding:24px;color:var(--fg4)">No data available yet.</td></tr>
        {% endfor %}
        {% for row in composite_rows %}
        <tr class="leaderboard-row" data-view="composite" data-sector-key="{{ row.key }}" data-sector-id="{{ row.sector_id }}" onclick="toggleBreakdown('{{ row.sector_id }}')">
          <td class="rank-cell">
            <span class="rank-badge{% if row.rank <= 3 %} top3{% endif %}">{{ row.rank }}</span>
            <span class="chevron" id="chev-{{ row.sector_id }}">▶</span>
          </td>
          <td>{{ row.sector }}{% if row.emerging %}<span class="emerging-badge">⬆ Emerging</span>{% endif %}</td>
          <td><span class="tag-region">Global</span></td>
          <td class="composite-cell">{{ row.composite }}</td>
          <td>{{ row.level_score }}</td>
          <td>{{ row.change_score }}</td>
          <td>{{ row.data_score }}</td>
          <td class="sentiment-cell">{{ row.sentiment_score }}</td>
          <td class="delta-cell">
            {% if row.arrow %}<span class="arrow {{ row.arrow_class }}">{{ row.arrow }}</span> {% endif %}{{ row.delta_rank }}
          </td>
          <td>
            <span class="traj-badge traj-{{ row.trajectory_state }}">{{ row.trajectory_label }}</span>
          </td>
        </tr>
        <tr class="breakdown-row" data-view="composite" id="bd-{{ row.sector_id }}">
          <td colspan="10">{{ row.breakdown_html | safe }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>

<!-- ============================================================
     Tab: RRG
     ============================================================ -->
<section id="tab-rrg" class="tab-panel">
  <p class="tab-note" data-i18n="note_sentiment">Sentiment weighting affects the leaderboard ranking only.</p>
  <details class="tab-guide">
    <summary data-i18n="guide_summary">How to read this tab</summary>
    <div class="tab-guide-body" data-i18n-html="guide_body_rrg">
      <p>Sectors are plotted by <strong>relative strength vs benchmark</strong> (x-axis) and whether that relative strength is <strong>accelerating or decelerating</strong> (y-axis). Both axes are centred at 100.</p>
      <h4>Four quadrants</h4>
      <ul>
        <li><strong>Leading (top-right):</strong> Outperforming AND accelerating. Currently strong — but watch for rotation into Weakening.</li>
        <li><strong>Weakening (bottom-right):</strong> Outperforming but decelerating. <span class="signal-lo">Prime exit / reduce signal.</span></li>
        <li><strong>Lagging (bottom-left):</strong> Underperforming AND decelerating. Avoid.</li>
        <li><strong>Improving (top-left):</strong> Underperforming but accelerating. <span class="signal-hi">Prime entry signal</span> — sectors typically rotate counter-clockwise from here into Leading.</li>
      </ul>
      <h4>How to use</h4>
      <p>Sectors rotate Leading → Weakening → Lagging → Improving → Leading. Buy in <span class="signal-hi">Improving</span> before the move to Leading; sell in <span class="signal-lo">Weakening</span> before the drop to Lagging. Dotted tail lines show the last 3 scan positions — the direction of the tail matters more than the current position.</p>
      <p><em>Note: current axes are composite-based proxies. True JdK RS-Ratio/Momentum requires daily price data relative to a benchmark.</em></p>
    </div>
  </details>
  <div class="chart-container" id="rrg-chart" style="height:520px"></div>
</section>

<!-- ============================================================
     Tab: Drill-down
     ============================================================ -->
<section id="tab-drilldown" class="tab-panel">
  <details class="tab-guide">
    <summary data-i18n="guide_summary">How to read this tab</summary>
    <div class="tab-guide-body" data-i18n-html="guide_body_drilldown">
      <p>Select a sector to see its score component history across all stored scans.</p>
      <h4>Key patterns</h4>
      <ul>
        <li><span class="signal-hi">Composite rising + Change score rising:</span> sustained acceleration. Highest-conviction entry setup.</li>
        <li><span class="signal-lo">Composite near peak + Change score turning negative:</span> the sector is topping. Reduce or exit.</li>
        <li>Composite falling but Change score rising: bottoming process. Watch for a second consecutive scan confirming before entering.</li>
        <li>Level score and Change score diverging: momentum structure is breaking down — treat with caution.</li>
      </ul>
      <h4>How to use</h4>
      <p>Pair with the leaderboard Trend badge. A sector showing <span class="signal-hi">↑</span> on the leaderboard that also has rising composite and change_score in the drill-down is the highest-conviction setup. A sector with a high rank but flat or falling change_score is likely to slip in the next scan.</p>
    </div>
  </details>
  <div class="drilldown-controls">
    <label for="sector-select">Sector:</label>
    <select class="sector-select" id="sector-select" onchange="updateDrilldown()">
      {% for sk in sector_keys %}
      <option value="{{ sk }}">{{ sk }}</option>
      {% endfor %}
    </select>
  </div>
  <div class="chart-container" id="drilldown-chart" style="height:460px"></div>
</section>

<!-- ============================================================
     Tab: Movers
     ============================================================ -->
<section id="tab-movers" class="tab-panel">
  <p class="tab-note" data-i18n="note_sentiment">Sentiment weighting affects the leaderboard ranking only.</p>
  <details class="tab-guide">
    <summary data-i18n="guide_summary">How to read this tab</summary>
    <div class="tab-guide-body" data-i18n-html="guide_body_movers">
      <p>Rank change between the two most recent scans. <span class="signal-hi">Green bars</span> = sectors that climbed the leaderboard; <span class="signal-lo">terracotta bars</span> = sectors that slipped.</p>
      <h4>How to use</h4>
      <ul>
        <li>A single large positive move can be a data event rather than sustained momentum — confirm in the Drill-down tab before acting.</li>
        <li>Sectors with 2+ consecutive large positive moves in the History tab carry more conviction than single-scan jumps.</li>
        <li><span class="signal-lo">Red flag:</span> a top-ranked sector with a large negative bar here is an early topping signal. Check the leaderboard Trend badge — if it shows <span class="signal-lo">↓</span> or <span class="signal-lo">↓↓</span>, the reversal is likely real.</li>
      </ul>
    </div>
  </details>
  <div class="chart-container" id="movers-chart" style="height:520px"></div>
</section>

<!-- ============================================================
     Tab: History
     ============================================================ -->
<section id="tab-history" class="tab-panel">
  <p class="tab-note" data-i18n="note_sentiment">Sentiment weighting affects the leaderboard ranking only.</p>
  <details class="tab-guide">
    <summary data-i18n="guide_summary">How to read this tab</summary>
    <div class="tab-guide-body" data-i18n-html="guide_body_history">
      <p>Composite score trend across all stored scans for every sector. The composite is a cross-sectional z-score — 0 = sector-average for that scan.</p>
      <h4>Key patterns</h4>
      <ul>
        <li><span class="signal-hi">Consistent upward slope:</span> quality momentum. The sector has been outperforming for multiple scans — this is the highest-quality signal.</li>
        <li><span class="signal-lo">Sharp spike then reversal:</span> likely a one-time data event, not sustainable momentum. Treat with caution.</li>
        <li>Gradual recovery from negative territory: potential emerging opportunity — cross-check the leaderboard Trend badge for confirmation.</li>
        <li>Flat around zero: sector in line with average; no edge.</li>
      </ul>
      <h4>How to use</h4>
      <p>Use as context for current rank. A sector ranked #1 after steadily rising for 10 scans is a different risk profile from one that jumped from #8 last scan. Long, smooth uptrends are the entries worth holding; V-shaped reversals are the ones to trade quickly or skip.</p>
    </div>
  </details>
  <div class="table-wrap scan-index">
    <table>
      <thead>
        <tr><th></th><th data-i18n="si_scan">Scan</th><th data-i18n="si_run">Run (UTC)</th><th data-i18n="si_sectors">Sectors</th><th data-i18n="si_top">Top sector</th><th data-i18n="si_report">Report</th></tr>
      </thead>
      <tbody>
        {% for s in scan_index %}
        <tr{% if s.scan_id == active_scan_id %} class="active-scan"{% endif %}>
          <td>{% if s.scan_id == active_scan_id %}<span class="showing-badge">● Showing</span>{% endif %}</td>
          <td>#{{ s.scan_id }}</td>
          <td>{{ s.run_at_display }}</td>
          <td>{{ s.sector_count }}</td>
          <td>{{ s.top_sector }} ({{ s.top_region }})</td>
          <td><a href="reports/report_{{ s.scan_id }}.md">download</a></td>
        </tr>
        {% else %}
        <tr><td colspan="6" style="text-align:center;padding:16px;color:var(--fg4)">No scans yet.</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  <div class="chart-container" id="history-chart" style="height:520px"></div>
</section>

<!-- ============================================================
     Tab: Backtest
     ============================================================ -->
<section id="tab-backtest" class="tab-panel">
  <p class="tab-note" data-i18n="note_backtest">Monthly top-{{ backtest_metrics[0].top_n if backtest_metrics else 5 }} rotation, equal-weight, long-only, no costs. Price-based signals only (breadth &amp; sentiment excluded). Each region scored within its own cohort.</p>
  {% if has_backtest %}
  <div class="table-wrap">
    <table>
      <thead><tr><th data-i18n="bt_track">Track</th><th data-i18n="bt_window">Window</th><th data-i18n="bt_stratcagr">Strategy CAGR</th><th data-i18n="bt_benchcagr">Bench CAGR</th><th data-i18n="bt_sharpe">Sharpe</th><th data-i18n="bt_maxdd">Max DD</th><th data-i18n="bt_hitrate">Hit rate</th><th data-i18n="bt_turnover">Turnover</th></tr></thead>
      <tbody>
        {% for r in backtest_metrics %}
        <tr><td>{{ r.region }}</td><td>{{ r.start }} → {{ r.end }}</td><td>{{ r.cagr }}</td><td>{{ r.benchmark_cagr }}</td><td>{{ r.sharpe }}</td><td>{{ r.max_drawdown }}</td><td>{{ r.hit_rate }}</td><td>{{ r.avg_turnover }}</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  <div class="chart-container" id="backtest-chart-US" style="height:420px"></div>
  <div class="chart-container" id="backtest-chart-EU" style="height:420px"></div>
  {% if has_rotations %}
  <h3 style="margin:22px 0 6px;font-family:var(--font-display);font-size:15px;color:var(--fg1)">Rotation event-study — did rank lead price?</h3>
  <p class="tab-note">Scanner rank (inverted: up = better) vs the sector ETF's indexed price across each curated rotation.</p>
  <div id="rotation-charts"></div>
  {% endif %}
  {% else %}
  <p style="text-align:center;padding:24px;color:var(--fg4)">No backtest run yet. Run <code>python backtest.py</code>.</p>
  {% endif %}
</section>

<!-- ============================================================
     Tab: Guide
     ============================================================ -->
<section id="tab-guide" class="tab-panel">
  <div class="guide" data-i18n-html="guide_tab">
    <h2>Leaderboard</h2>
    <p>
      The leaderboard ranks every sector by its <strong>composite score</strong> — a
      weighted blend of level, momentum-change, and data-quality sub-scores. A higher
      composite (more positive z-score) means the sector is exhibiting stronger relative
      momentum versus its benchmark.
    </p>
    <ul>
      <li><strong>Level score</strong> — captures the current absolute momentum level
          (returns, MA structure, OBV trend).</li>
      <li><strong>Change score</strong> — captures how momentum is accelerating or
          decelerating versus the prior scan.</li>
      <li><strong>Data score</strong> — reflects data completeness; sectors with missing
          signals are penalised.</li>
      <li><strong>Rank Δ</strong> — how many ranks the sector climbed (▲) or fell (▼)
          versus the previous scan.</li>
    </ul>
    <p>Click any column header to sort the table.</p>

    <h2>Relative Rotation Graph (RRG)</h2>
    <p>
      The RRG plots sectors on two axes derived from their relative strength vs the
      benchmark index:
    </p>
    <ul>
      <li><strong>X-axis (RS-Ratio)</strong> — whether the sector is outperforming (&gt; 100)
          or underperforming (&lt; 100) the benchmark.</li>
      <li><strong>Y-axis (RS-Momentum)</strong> — whether relative strength is
          accelerating (&gt; 100) or decelerating (&lt; 100).</li>
    </ul>
    <p>Quadrant interpretation:</p>
    <ul>
      <li><strong>Leading</strong> (top-right) — outperforming and accelerating.</li>
      <li><strong>Weakening</strong> (bottom-right) — outperforming but decelerating.</li>
      <li><strong>Lagging</strong> (bottom-left) — underperforming and decelerating.</li>
      <li><strong>Improving</strong> (top-left) — underperforming but accelerating.</li>
    </ul>
    <p>
      Dotted tail lines show the last 5 scan positions per sector, indicating rotation
      direction. Sectors rotating clockwise from Improving → Leading are the strongest
      early-trend setups.
    </p>

    <h2>Drill-down</h2>
    <p>
      Select a sector from the dropdown to view how each score component has evolved over
      time. Useful for spotting multi-scan trends — a rising <em>change_score</em>
      alongside a rising <em>composite</em> is a strong signal of sustained momentum.
    </p>

    <h2>Movers</h2>
    <p>
      The movers panel shows the rank change between the two most recent scans.
      <span style="color:var(--up)">Green bars</span> indicate sectors that climbed the
      leaderboard; <span style="color:var(--down)">terracotta bars</span> indicate sectors that
      slipped. Large moves may reflect data updates, macro events, or genuine momentum
      shifts.
    </p>

    <h2>History</h2>
    <p>
      A line chart of composite score across all stored scans. Persistent upward trends
      in a sector's composite score indicate sustained momentum, while reversals may
      signal rotation into or out of the sector.
    </p>

    <h2>Disclaimer</h2>
    <p>
      <strong>This tool is for analytical and educational purposes only.</strong>
      It does not constitute investment advice or a recommendation to buy, sell, or hold
      any security. Past momentum is not indicative of future returns. Always perform
      your own due diligence and consult a qualified financial adviser before making
      investment decisions.
    </p>
  </div>
</section>

<!-- ============================================================
     JavaScript
     ============================================================ -->
<script>
// ----- Tab switching -----
function switchTab(name, btn) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  btn.classList.add('active');

  // Lazy-render Plotly charts on first activation
  if (name === 'rrg')       renderRRG();
  if (name === 'movers')    renderMovers();
  if (name === 'history')   renderHistory();
  if (name === 'drilldown') renderDrilldown();
  if (name === 'backtest')  renderBacktest();
}

// ----- Plotly data (injected by build.py) -----
var RRG_DATA    = {{ rrg_data_json | safe }};
var MOVERS_DATA = {{ movers_json | safe }};
var HISTORY_DATA = {{ history_json | safe }};
var DRILLDOWN_DATA = {{ drilldown_data | safe }};
var RESCORE_DATA = {{ rescore_data_json | safe }};
var BACKTEST_DATA = {{ backtest_json | safe }};
var ROTATION_DATA = {{ rotation_json | safe }};

// ----- Render helpers -----
var _rendered = {};

function renderRRG() {
  if (_rendered.rrg) return;
  _rendered.rrg = true;
  Plotly.newPlot('rrg-chart', RRG_DATA.data, RRG_DATA.layout, {responsive: true, displayModeBar: true});
}

function renderMovers() {
  if (_rendered.movers) return;
  _rendered.movers = true;
  Plotly.newPlot('movers-chart', MOVERS_DATA.data, MOVERS_DATA.layout, {responsive: true, displayModeBar: true});
}

function renderHistory() {
  if (_rendered.history) return;
  _rendered.history = true;
  Plotly.newPlot('history-chart', HISTORY_DATA.data, HISTORY_DATA.layout, {responsive: true, displayModeBar: true});
}

function renderBacktest() {
  if (_rendered.backtest) return;
  _rendered.backtest = true;
  ['US', 'EU'].forEach(function (rg) {
    var el = document.getElementById('backtest-chart-' + rg);
    if (el && BACKTEST_DATA[rg]) {
      var f = BACKTEST_DATA[rg];
      Plotly.newPlot(el, f.data, f.layout, {responsive: true, displayModeBar: true});
    }
  });
  var rc = document.getElementById('rotation-charts');
  if (rc && !rc.dataset.rendered && ROTATION_DATA && ROTATION_DATA.length) {
    rc.dataset.rendered = '1';
    ROTATION_DATA.forEach(function (r, i) {
      var d = document.createElement('div');
      d.className = 'chart-container';
      d.style.height = '360px';
      d.style.marginBottom = '16px';
      d.id = 'rotation-chart-' + i;
      rc.appendChild(d);
      Plotly.newPlot(d, r.fig.data, r.fig.layout, {responsive: true, displayModeBar: true});
    });
  }
}

function renderDrilldown() {
  _rendered.drilldown = false; // always re-render on sector change
  updateDrilldown();
}

function updateDrilldown() {
  var sel = document.getElementById('sector-select');
  if (!sel) return;
  var key = sel.value;
  var figJson = DRILLDOWN_DATA[key];
  if (!figJson) {
    document.getElementById('drilldown-chart').innerHTML =
      '<p style="padding:24px;color:var(--fg4)">No data for ' + key + '</p>';
    return;
  }
  var fig = typeof figJson === 'string' ? JSON.parse(figJson) : figJson;
  Plotly.newPlot('drilldown-chart', fig.data, fig.layout, {responsive: true, displayModeBar: true});
}

// ----- Breakdown toggle -----
function toggleBreakdown(id) {
  var bdRow = document.getElementById('bd-' + id);
  var chev  = document.getElementById('chev-' + id);
  if (!bdRow) return;
  bdRow.classList.toggle('open');
  if (chev) chev.textContent = bdRow.classList.contains('open') ? '▼' : '▶';
}

// ----- Sortable table -----
var _sortCol = 0, _sortDir = 1; // dir: 1=asc, -1=desc

function sortTable(col) {
  var table   = document.getElementById('leaderboard-table');
  var tbody   = table.querySelector('tbody');
  var headers = table.querySelectorAll('thead th');
  // Only sort leaderboard rows — skip breakdown rows; scope to active view
  var view = (table.getAttribute('data-view') || 'split');
  var rows = Array.from(tbody.querySelectorAll('tr.leaderboard-row[data-view="' + view + '"]'));

  if (_sortCol === col) {
    _sortDir *= -1;
  } else {
    _sortCol = col;
    _sortDir = 1;
  }

  headers.forEach(function(h, i) {
    h.classList.remove('sort-asc', 'sort-desc');
    if (i === col) h.classList.add(_sortDir === 1 ? 'sort-asc' : 'sort-desc');
  });

  rows.sort(function(a, b) {
    var aCell = a.querySelectorAll('td')[col];
    var bCell = b.querySelectorAll('td')[col];
    var aText = aCell ? aCell.innerText.trim() : '';
    var bText = bCell ? bCell.innerText.trim() : '';

    aText = aText.replace(/[▲▼▶]/g, '').trim();
    bText = bText.replace(/[▲▼▶]/g, '').trim();

    var aNum = parseFloat(aText.replace(/[+,]/g, ''));
    var bNum = parseFloat(bText.replace(/[+,]/g, ''));

    if (!isNaN(aNum) && !isNaN(bNum)) return (aNum - bNum) * _sortDir;
    return aText.localeCompare(bText) * _sortDir;
  });

  // Re-append each leaderboard row followed by its breakdown row
  rows.forEach(function(r) {
    tbody.appendChild(r);
    var sectorId = r.dataset.sectorId;
    if (sectorId) {
      var bd = document.getElementById('bd-' + sectorId);
      if (bd) tbody.appendChild(bd);
    }
  });

}

// ----- Sentiment + sector-view toggle wiring -----
(function () {
  var LS_ENABLED = "sentimentEnabled", LS_WEIGHT = "sentimentWeight", LS_VIEW = "sectorView";
  var toggle = document.getElementById("sentiment-toggle");
  var weightInput = document.getElementById("sentiment-weight");
  var viewSel = document.getElementById("sector-view-toggle");
  var table = document.getElementById("leaderboard-table");
  var weightWrap = weightInput ? weightInput.closest(".sw-weight") : null;
  if (!toggle || !weightInput || !viewSel || !table || typeof Rescore === "undefined") { return; }

  function readView() {
    try { return localStorage.getItem(LS_VIEW) === "composite" ? "composite" : "split"; }
    catch (e) { return "split"; }
  }
  function fmt(n, d) { return (n === null || n === undefined) ? "—" : Number(n).toFixed(d); }

  // Update every score-tree on the page whose key is in `scored`. A split
  // breakdown row and a composite sub-panel can carry the SAME data-sector-key
  // (the composite panel embeds the regional breakdowns verbatim), so update
  // ALL matches, not just the first.
  function updateTrees(scored, W) {
    var dataPct = Math.round((1 - W) * 100), sentPct = Math.round(W * 100);
    Object.keys(scored).forEach(function (key) {
      var sel = '.score-tree[data-sector-key="' + (window.CSS && CSS.escape ? CSS.escape(key) : key) + '"]';
      document.querySelectorAll(sel).forEach(function (tree) {
        var cv = tree.querySelector(".st-composite-val");
        if (cv) { cv.textContent = fmt(scored[key].composite, 3); }
        var dwt = tree.querySelector(".st-data-wt"); if (dwt) { dwt.textContent = "(" + dataPct + "%)"; }
        var swt = tree.querySelector(".st-sent-wt"); if (swt) { swt.textContent = "(" + sentPct + "%)"; }
      });
    });
  }

  // Update the visible leaderboard rows' cells from `scored`.
  function updateRows(rows, scored) {
    rows.forEach(function (tr) {
      var r = scored[tr.getAttribute("data-sector-key")];
      if (!r) { return; }
      var badge = tr.querySelector(".rank-cell .rank-badge");
      if (badge) { badge.textContent = r.rank; badge.classList.toggle("top3", r.rank <= 3); }
      var compCell = tr.querySelector(".composite-cell");
      if (compCell) { compCell.textContent = fmt(r.composite, 3); }
      var deltaCell = tr.querySelector(".delta-cell");
      if (deltaCell) {
        var arrow = r.delta_rank > 0 ? "▲" : (r.delta_rank < 0 ? "▼" : "");
        var cls = r.delta_rank > 0 ? "up" : (r.delta_rank < 0 ? "down" : "");
        var dtxt = r.delta_rank === 0 ? "—" : (r.delta_rank > 0 ? "+" : "") + r.delta_rank.toFixed(1);
        deltaCell.innerHTML = '<span class="arrow ' + cls + '">' + arrow + '</span> ' + dtxt;
      }
      var traj = tr.querySelector(".traj-badge");
      if (traj) { traj.className = "traj-badge traj-" + r.trajectory_state; traj.textContent = r.trajectory_label; }
      var sectorCell = tr.querySelectorAll("td")[1];
      if (sectorCell) {
        var ebadge = sectorCell.querySelector(".emerging-badge");
        if (r.emerging && !ebadge) {
          var s = document.createElement("span");
          s.className = "emerging-badge"; s.textContent = "⬆ Emerging";
          sectorCell.appendChild(s);
        } else if (!r.emerging && ebadge) { ebadge.remove(); }
      }
    });
  }

  function sortVisibleByRank(rows, scored, tbody) {
    rows.sort(function (a, b) {
      var ra = scored[a.getAttribute("data-sector-key")];
      var rb = scored[b.getAttribute("data-sector-key")];
      return (ra ? ra.rank : 1e9) - (rb ? rb.rank : 1e9);
    });
    rows.forEach(function (tr) {
      tbody.appendChild(tr);
      var sid = tr.getAttribute("data-sector-id");
      var bd = sid ? document.getElementById("bd-" + sid) : null;
      if (bd) { tbody.appendChild(bd); }
    });
  }

  function applyRanking() {
    var enabled = toggle.checked;
    var weight = Math.min(100, Math.max(0, parseInt(weightInput.value, 10) || 0));
    var W = enabled ? weight / 100 : 0;
    var view = viewSel.value === "composite" ? "composite" : "split";
    try {
      localStorage.setItem(LS_ENABLED, enabled ? "true" : "false");
      localStorage.setItem(LS_WEIGHT, String(weight));
      localStorage.setItem(LS_VIEW, view);
    } catch (e) {}
    weightInput.disabled = !enabled;
    if (weightWrap) { weightWrap.setAttribute("data-disabled", String(!enabled)); }

    // Compute both maps so breakdown sub-panels stay live in either view.
    var scoredSplit = Rescore.rescore(RESCORE_DATA, W);
    var scoredComposite = Rescore.rescore(Rescore.mergeComposite(RESCORE_DATA), W);
    updateTrees(scoredSplit, W);
    updateTrees(scoredComposite, W);

    table.setAttribute("data-view", view);
    var activeScored = view === "composite" ? scoredComposite : scoredSplit;
    var tbody = table.querySelector("tbody");
    var rows = Array.prototype.slice.call(
      tbody.querySelectorAll('tr.leaderboard-row[data-view="' + view + '"]'));
    updateRows(rows, activeScored);
    sortVisibleByRank(rows, activeScored, tbody);
  }

  // Init from persisted state.
  var enabled0 = false, weight0 = 30;
  try {
    enabled0 = localStorage.getItem(LS_ENABLED) === "true";
    var w = parseInt(localStorage.getItem(LS_WEIGHT), 10);
    if (!isNaN(w)) { weight0 = Math.min(100, Math.max(0, w)); }
  } catch (e) {}
  toggle.checked = enabled0;
  weightInput.value = weight0;
  viewSel.value = readView();
  table.setAttribute("data-view", viewSel.value);
  toggle.addEventListener("change", applyRanking);
  weightInput.addEventListener("input", applyRanking);
  viewSel.addEventListener("change", applyRanking);
  applyRanking();
})();

{% include "_i18n.html.j2" %}
</script>


<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Sector Momentum</title>
<script src="{{ plotly_bundle }}"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Familjen+Grotesk:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --beige-50:  #FAF7F0;
  --beige-100: #F5F0E6;
  --beige-200: #EDE6D6;
  --beige-300: #DFD5BE;
  --beige-400: #C4B89A;
  --beige-500: #8F8568;
  --beige-600: #5E5742;
  --beige-700: #3E392B;
  --beige-900: #1F1C15;

  --green-100: #E2EBD9;
  --green-300: #A9BF95;
  --green-400: #8FA77A;
  --green-600: #5A6F49;
  --green-700: #455636;

  --terra-400: #BF6F50;
  --terra-500: #A55A3C;

  --bg:           var(--beige-100);
  --bg-raised:    var(--beige-50);
  --bg-sunken:    var(--beige-200);
  --fg1:          var(--beige-900);
  --fg2:          var(--beige-700);
  --fg3:          var(--beige-600);
  --fg4:          var(--beige-500);
  --brand-strong: var(--green-600);
  --border:       var(--beige-300);
  --border-soft:  var(--beige-200);
  --up:           var(--green-600);
  --down:         var(--terra-500);

  --font-display: 'Familjen Grotesk', 'Helvetica Neue', system-ui, sans-serif;
  --font-body:    'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
  --font-mono:    'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace;

  --radius-sm:   4px;
  --radius-md:   8px;
  --radius-lg:   14px;
  --radius-pill: 999px;

  --shadow-xs: 0 1px 2px rgba(62,57,43,0.06);
  --shadow-sm: 0 1px 2px rgba(62,57,43,0.05), 0 2px 6px rgba(62,57,43,0.04);

  --ease-standard: cubic-bezier(0.2,0.6,0.2,1);
  --duration-fast: 140ms;
}

html, body {
  background: var(--bg);
  color: var(--fg2);
  font-family: var(--font-body);
  font-size: 14px;
  line-height: 1.5;
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
}

/* =========================================================
   Header
   ========================================================= */
header {
  background: var(--bg-raised);
  border-bottom: 1px solid var(--border);
  padding: 16px 28px;
  display: flex;
  align-items: baseline;
  gap: 16px;
  flex-wrap: wrap;
}
header h1 {
  font-family: var(--font-display);
  font-size: 22px;
  font-weight: 600;
  color: var(--fg1);
  letter-spacing: -0.02em;
  line-height: 1;
}
.scan-date {
  font-size: 12px;
  color: var(--fg4);
}
.disclaimer {
  margin-left: auto;
  font-size: 11px;
  color: var(--fg4);
  border: 1px solid var(--border-soft);
  border-radius: var(--radius-pill);
  padding: 3px 10px;
}

/* =========================================================
   Tab bar
   ========================================================= */
.tabs {
  display: flex;
  background: var(--bg-raised);
  border-bottom: 1px solid var(--border);
  overflow-x: auto;
  padding: 0 24px;
}
.tab-btn {
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  color: var(--fg4);
  cursor: pointer;
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 500;
  padding: 11px 16px;
  white-space: nowrap;
  transition: color var(--duration-fast) var(--ease-standard),
              border-color var(--duration-fast) var(--ease-standard);
}
.tab-btn:hover { color: var(--fg2); }
.tab-btn.active {
  color: var(--brand-strong);
  border-bottom-color: var(--brand-strong);
}

/* =========================================================
   Tab content panels
   ========================================================= */
.tab-panel { display: none; padding: 24px 28px; }
.tab-panel.active { display: block; }

/* =========================================================
   Leaderboard table
   ========================================================= */
.table-wrap {
  overflow-x: auto;
  border-radius: var(--radius-lg);
  border: 1px solid var(--border-soft);
  background: var(--bg-raised);
  box-shadow: var(--shadow-xs);
}
table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
}
thead tr {
  background: var(--bg-sunken);
  border-bottom: 1px solid var(--border);
}
thead th {
  padding: 10px 16px;
  text-align: left;
  color: var(--fg4);
  font-size: 10px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.10em;
  cursor: pointer;
  user-select: none;
  white-space: nowrap;
}
thead th:hover { color: var(--fg2); }
thead th.sort-asc::after  { content: " ▲"; font-size: 0.75em; }
thead th.sort-desc::after { content: " ▼"; font-size: 0.75em; }
tbody tr { border-bottom: 1px dashed var(--border-soft); }
tbody tr:last-child { border-bottom: none; }
tbody td {
  padding: 11px 16px;
  vertical-align: middle;
  color: var(--fg2);
}
tbody td:nth-child(n+4) {
  font-family: var(--font-mono);
  font-size: 12px;
}
.rank-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 26px;
  height: 26px;
  border-radius: 50%;
  background: var(--bg-sunken);
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 12px;
  color: var(--fg3);
}
.rank-badge.top3 {
  background: var(--green-100);
  color: var(--green-700);
}
.arrow.up   { color: var(--up);   font-size: 11px; }
.arrow.down { color: var(--down); font-size: 11px; }
.tag-region {
  display: inline-block;
  font-size: 10px;
  font-weight: 500;
  padding: 2px 8px;
  border-radius: var(--radius-pill);
  background: var(--beige-200);
  color: var(--fg3);
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

/* =========================================================
   Plotly chart containers
   ========================================================= */
.chart-container {
  background: var(--bg-raised);
  border: 1px solid var(--border-soft);
  border-radius: var(--radius-lg);
  overflow: hidden;
  min-height: 420px;
  box-shadow: var(--shadow-xs);
}

/* =========================================================
   Drill-down panel
   ========================================================= */
.drilldown-controls {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
  flex-wrap: wrap;
}
.drilldown-controls label {
  color: var(--fg4);
  font-size: 10px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.10em;
}
select.sector-select {
  background: var(--bg-raised);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  color: var(--fg1);
  font-family: var(--font-body);
  font-size: 13px;
  padding: 7px 12px;
  cursor: pointer;
  min-width: 220px;
  outline: none;
  transition: border-color var(--duration-fast) var(--ease-standard);
}
select.sector-select:focus {
  border-color: var(--green-400);
  box-shadow: 0 0 0 3px rgba(143,167,122,0.2);
}

/* =========================================================
   Guide panel
   ========================================================= */
.guide {
  max-width: 680px;
  line-height: 1.7;
}
.guide h2 {
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: 500;
  color: var(--fg1);
  letter-spacing: -0.01em;
  margin-top: 28px;
  margin-bottom: 8px;
}
.guide h2:first-child { margin-top: 0; }
.guide p { color: var(--fg3); margin-bottom: 10px; font-size: 14px; }
.guide ul { padding-left: 18px; color: var(--fg3); margin-bottom: 10px; font-size: 14px; }
.guide li { margin-bottom: 5px; }
.guide strong { color: var(--fg2); font-weight: 500; }

/* =========================================================
   Responsive
   ========================================================= */
@media (max-width: 600px) {
  header { padding: 12px 16px; }
  .tab-panel { padding: 14px 16px; }
  .tabs { padding: 0 8px; }
}

/* =========================================================
   Leaderboard row breakdown
   ========================================================= */
.leaderboard-row { cursor: pointer; }
.leaderboard-row:hover { background: rgba(143,167,122,0.06); }
.chevron {
  font-size: 0.6em;
  color: var(--fg4);
  margin-left: 5px;
  display: inline-block;
  transition: transform var(--duration-fast) var(--ease-standard);
}
.breakdown-row { display: none; }
.breakdown-row.open { display: table-row; }
.breakdown-inner {
  padding: 16px 20px;
  background: var(--bg-sunken);
  border-top: 1px solid var(--border-soft);
}
.breakdown-grid {
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: 24px;
  align-items: start;
}
@media (max-width: 700px) { .breakdown-grid { grid-template-columns: 1fr; } }

/* Score tree */
.score-tree {
  font-family: var(--font-mono);
  font-size: 12px;
  line-height: 2;
}
.st-row { display: flex; align-items: baseline; gap: 4px; }
.st-top .st-label { font-weight: 600; color: var(--fg1); }
.st-top .st-val   { font-weight: 600; color: var(--brand-strong); }
.st-conn  { color: var(--fg4); white-space: pre; min-width: 2.5em; }
.st-label { color: var(--fg3); }
.st-wt    { color: var(--fg4); font-size: 0.9em; }
.st-val   { color: var(--fg2); margin-left: auto; min-width: 48px; text-align: right; }
.st-meta  { color: var(--fg4); font-size: 0.85em; margin-left: 4px; }
.bd-footer {
  margin-top: 10px;
  font-size: 11px;
  color: var(--fg4);
  border-top: 1px dashed var(--border-soft);
  padding-top: 8px;
  font-family: var(--font-mono);
}

/* Signal tables */
.sig-section { margin-bottom: 12px; }
.sig-title {
  font-size: 10px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.10em;
  color: var(--fg4);
  margin-bottom: 5px;
}
.sig-table { border-collapse: collapse; width: 100%; font-size: 12px; }
.sig-table td { padding: 3px 6px; vertical-align: middle; }
.sig-label { color: var(--fg3); white-space: nowrap; }
.sig-raw   { color: var(--fg2); font-family: var(--font-mono); text-align: right; min-width: 54px; }
.sig-bar   { padding: 0 8px; }
.sig-z     { color: var(--fg4); font-family: var(--font-mono); text-align: right; min-width: 46px; }
.z-bar-wrap {
  display: inline-block;
  width: 60px; height: 6px;
  background: var(--beige-300);
  border-radius: var(--radius-pill);
  vertical-align: middle;
}
.z-bar {
  display: inline-block;
  height: 6px;
  border-radius: var(--radius-pill);
}
.sig-chip   { font-size: 11px; }
.sig-chip.bull { color: var(--green-600); }
.sig-chip.bear { color: var(--terra-500); }
.sig-chip.neut { color: var(--fg4); }
.sig-info {
  font-size: 11px;
  color: var(--fg4);
  margin-top: 8px;
  border-top: 1px dashed var(--border-soft);
  padding-top: 6px;
}
.info-lbl { font-weight: 500; }
</style>
</head>
<body>

<!-- Header -->
<header>
  <h1>Sector momentum</h1>
  <span class="scan-date">Last scan: {{ scan_date }}</span>
  <span class="disclaimer">Analytical tooling, not investment advice.</span>
</header>

<!-- Tab bar -->
<nav class="tabs" role="tablist">
  <button class="tab-btn active" onclick="switchTab('leaderboard', this)" role="tab">Leaderboard</button>
  <button class="tab-btn" onclick="switchTab('rrg', this)" role="tab">RRG</button>
  <button class="tab-btn" onclick="switchTab('drilldown', this)" role="tab">Drill-down</button>
  <button class="tab-btn" onclick="switchTab('movers', this)" role="tab">Movers</button>
  <button class="tab-btn" onclick="switchTab('history', this)" role="tab">History</button>
  <button class="tab-btn" onclick="switchTab('sentiment', this)" role="tab">Data ⇄ Sentiment</button>
  <button class="tab-btn" onclick="switchTab('guide', this)" role="tab">Guide</button>
</nav>

<!-- ============================================================
     Tab: Leaderboard
     ============================================================ -->
<section id="tab-leaderboard" class="tab-panel active">
  <div class="table-wrap">
    <table id="leaderboard-table">
      <thead>
        <tr>
          <th onclick="sortTable(0)" data-col="0">#</th>
          <th onclick="sortTable(1)" data-col="1">Sector</th>
          <th onclick="sortTable(2)" data-col="2">Region</th>
          <th onclick="sortTable(3)" data-col="3">Composite</th>
          <th onclick="sortTable(4)" data-col="4">Level</th>
          <th onclick="sortTable(5)" data-col="5">Change</th>
          <th onclick="sortTable(6)" data-col="6">Data</th>
          <th onclick="sortTable(7)" data-col="7">Sentiment</th>
          <th onclick="sortTable(8)" data-col="8">Rank Δ</th>
        </tr>
      </thead>
      <tbody>
        {% for row in leaderboard_rows %}
        <tr class="leaderboard-row" data-sector-id="{{ row.sector_id }}" onclick="toggleBreakdown('{{ row.sector_id }}')">
          <td>
            <span class="rank-badge{% if row.rank <= 3 %} top3{% endif %}">{{ row.rank }}</span>
            <span class="chevron" id="chev-{{ row.sector_id }}">▶</span>
          </td>
          <td>{{ row.sector }}</td>
          <td><span class="tag-region">{{ row.region }}</span></td>
          <td>{{ row.composite }}</td>
          <td>{{ row.level_score }}</td>
          <td>{{ row.change_score }}</td>
          <td>{{ row.data_score }}</td>
          <td>{{ row.sentiment_score }}</td>
          <td>
            {% if row.arrow %}<span class="arrow {{ row.arrow_class }}">{{ row.arrow }}</span> {% endif %}{{ row.delta_rank }}
          </td>
        </tr>
        <tr class="breakdown-row" id="bd-{{ row.sector_id }}">
          <td colspan="9">{{ row.breakdown_html | safe }}</td>
        </tr>
        {% else %}
        <tr><td colspan="9" style="text-align:center;padding:24px;color:var(--fg4)">No data available yet.</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>

<!-- ============================================================
     Tab: RRG
     ============================================================ -->
<section id="tab-rrg" class="tab-panel">
  <div class="chart-container" id="rrg-chart" style="height:520px"></div>
</section>

<!-- ============================================================
     Tab: Drill-down
     ============================================================ -->
<section id="tab-drilldown" class="tab-panel">
  <div class="drilldown-controls">
    <label for="sector-select">Sector:</label>
    <select class="sector-select" id="sector-select" onchange="updateDrilldown()">
      {% for sk in sector_keys %}
      <option value="{{ sk }}">{{ sk }}</option>
      {% endfor %}
    </select>
  </div>
  <div class="chart-container" id="drilldown-chart" style="height:460px"></div>
</section>

<!-- ============================================================
     Tab: Movers
     ============================================================ -->
<section id="tab-movers" class="tab-panel">
  <div class="chart-container" id="movers-chart" style="height:520px"></div>
</section>

<!-- ============================================================
     Tab: History
     ============================================================ -->
<section id="tab-history" class="tab-panel">
  <div class="chart-container" id="history-chart" style="height:520px"></div>
</section>

<!-- ============================================================
     Tab: Data ⇄ Sentiment
     ============================================================ -->
<section id="tab-sentiment" class="tab-panel">
  <div class="chart-container" id="sentiment-scatter" style="height:560px"></div>
  <p style="color:var(--text-muted);font-size:0.8rem;padding:8px 0 0 4px">
    Bottom-right quadrant (data ahead of sentiment) is the early-rotation zone.
    Hollow points = no sentiment data this scan (source unavailable or EU-only).
    Sentiment is a confirming signal — noisy, gameable, retail-biased.
    This is analytical tooling, not investment advice.
  </p>
</section>

<!-- ============================================================
     Tab: Guide
     ============================================================ -->
<section id="tab-guide" class="tab-panel">
  <div class="guide">
    <h2>Leaderboard</h2>
    <p>
      The leaderboard ranks every sector by its <strong>composite score</strong> — a
      weighted blend of level, momentum-change, and data-quality sub-scores. A higher
      composite (more positive z-score) means the sector is exhibiting stronger relative
      momentum versus its benchmark.
    </p>
    <ul>
      <li><strong>Level score</strong> — captures the current absolute momentum level
          (returns, MA structure, OBV trend).</li>
      <li><strong>Change score</strong> — captures how momentum is accelerating or
          decelerating versus the prior scan.</li>
      <li><strong>Data score</strong> — reflects data completeness; sectors with missing
          signals are penalised.</li>
      <li><strong>Rank Δ</strong> — how many ranks the sector climbed (▲) or fell (▼)
          versus the previous scan.</li>
    </ul>
    <p>Click any column header to sort the table.</p>

    <h2>Relative Rotation Graph (RRG)</h2>
    <p>
      The RRG plots sectors on two axes derived from their relative strength vs the
      benchmark index:
    </p>
    <ul>
      <li><strong>X-axis (RS-Ratio)</strong> — whether the sector is outperforming (&gt; 100)
          or underperforming (&lt; 100) the benchmark.</li>
      <li><strong>Y-axis (RS-Momentum)</strong> — whether relative strength is
          accelerating (&gt; 100) or decelerating (&lt; 100).</li>
    </ul>
    <p>Quadrant interpretation:</p>
    <ul>
      <li><strong>Leading</strong> (top-right) — outperforming and accelerating.</li>
      <li><strong>Weakening</strong> (bottom-right) — outperforming but decelerating.</li>
      <li><strong>Lagging</strong> (bottom-left) — underperforming and decelerating.</li>
      <li><strong>Improving</strong> (top-left) — underperforming but accelerating.</li>
    </ul>
    <p>
      Dotted tail lines show the last 3 scan positions, indicating rotation direction.
      Note: in Phase 1 the axes are proxies derived from composite score and rank;
      true JdK RS-Ratio values require the RRG signal data from the signals table.
    </p>

    <h2>Drill-down</h2>
    <p>
      Select a sector from the dropdown to view how each score component has evolved over
      time. Useful for spotting multi-scan trends — a rising <em>change_score</em>
      alongside a rising <em>composite</em> is a strong signal of sustained momentum.
    </p>

    <h2>Movers</h2>
    <p>
      The movers panel shows the rank change between the two most recent scans.
      <span style="color:var(--up)">Green bars</span> indicate sectors that climbed the
      leaderboard; <span style="color:var(--down)">terracotta bars</span> indicate sectors that
      slipped. Large moves may reflect data updates, macro events, or genuine momentum
      shifts.
    </p>

    <h2>History</h2>
    <p>
      A line chart of composite score across all stored scans. Persistent upward trends
      in a sector's composite score indicate sustained momentum, while reversals may
      signal rotation into or out of the sector.
    </p>

    <h2>Disclaimer</h2>
    <p>
      <strong>This tool is for analytical and educational purposes only.</strong>
      It does not constitute investment advice or a recommendation to buy, sell, or hold
      any security. Past momentum is not indicative of future returns. Always perform
      your own due diligence and consult a qualified financial adviser before making
      investment decisions.
    </p>
  </div>
</section>

<!-- ============================================================
     JavaScript
     ============================================================ -->
<script>
// ----- Tab switching -----
function switchTab(name, btn) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  btn.classList.add('active');

  // Lazy-render Plotly charts on first activation
  if (name === 'rrg')       renderRRG();
  if (name === 'movers')    renderMovers();
  if (name === 'history')   renderHistory();
  if (name === 'drilldown') renderDrilldown();
  if (name === 'sentiment') renderSentiment();
}

// ----- Plotly data (injected by build.py) -----
var RRG_DATA    = {{ rrg_data_json | safe }};
var MOVERS_DATA = {{ movers_json | safe }};
var HISTORY_DATA = {{ history_json | safe }};
var DRILLDOWN_DATA = {{ drilldown_data | safe }};
var SENTIMENT_DATA = {{ sentiment_scatter_json | safe }};

// ----- Render helpers -----
var _rendered = {};

function renderRRG() {
  if (_rendered.rrg) return;
  _rendered.rrg = true;
  Plotly.newPlot('rrg-chart', RRG_DATA.data, RRG_DATA.layout, {responsive: true, displayModeBar: true});
}

function renderMovers() {
  if (_rendered.movers) return;
  _rendered.movers = true;
  Plotly.newPlot('movers-chart', MOVERS_DATA.data, MOVERS_DATA.layout, {responsive: true, displayModeBar: true});
}

function renderHistory() {
  if (_rendered.history) return;
  _rendered.history = true;
  Plotly.newPlot('history-chart', HISTORY_DATA.data, HISTORY_DATA.layout, {responsive: true, displayModeBar: true});
}

function renderSentiment() {
  if (_rendered.sentiment) return;
  _rendered.sentiment = true;
  Plotly.newPlot('sentiment-scatter', SENTIMENT_DATA.data, SENTIMENT_DATA.layout, {responsive: true});
}

function renderDrilldown() {
  _rendered.drilldown = false; // always re-render on sector change
  updateDrilldown();
}

function updateDrilldown() {
  var sel = document.getElementById('sector-select');
  if (!sel) return;
  var key = sel.value;
  var figJson = DRILLDOWN_DATA[key];
  if (!figJson) {
    document.getElementById('drilldown-chart').innerHTML =
      '<p style="padding:24px;color:var(--fg4)">No data for ' + key + '</p>';
    return;
  }
  var fig = typeof figJson === 'string' ? JSON.parse(figJson) : figJson;
  Plotly.newPlot('drilldown-chart', fig.data, fig.layout, {responsive: true, displayModeBar: true});
}

// ----- Breakdown toggle -----
function toggleBreakdown(id) {
  var bdRow = document.getElementById('bd-' + id);
  var chev  = document.getElementById('chev-' + id);
  if (!bdRow) return;
  bdRow.classList.toggle('open');
  if (chev) chev.textContent = bdRow.classList.contains('open') ? '▼' : '▶';
}

// ----- Sortable table -----
var _sortCol = 0, _sortDir = 1; // dir: 1=asc, -1=desc

function sortTable(col) {
  var table   = document.getElementById('leaderboard-table');
  var tbody   = table.querySelector('tbody');
  var headers = table.querySelectorAll('thead th');
  // Only sort leaderboard rows — skip breakdown rows
  var rows = Array.from(tbody.querySelectorAll('tr.leaderboard-row'));

  if (_sortCol === col) {
    _sortDir *= -1;
  } else {
    _sortCol = col;
    _sortDir = 1;
  }

  headers.forEach(function(h, i) {
    h.classList.remove('sort-asc', 'sort-desc');
    if (i === col) h.classList.add(_sortDir === 1 ? 'sort-asc' : 'sort-desc');
  });

  rows.sort(function(a, b) {
    var aCell = a.querySelectorAll('td')[col];
    var bCell = b.querySelectorAll('td')[col];
    var aText = aCell ? aCell.innerText.trim() : '';
    var bText = bCell ? bCell.innerText.trim() : '';

    aText = aText.replace(/[▲▼▶]/g, '').trim();
    bText = bText.replace(/[▲▼▶]/g, '').trim();

    var aNum = parseFloat(aText.replace(/[+,]/g, ''));
    var bNum = parseFloat(bText.replace(/[+,]/g, ''));

    if (!isNaN(aNum) && !isNaN(bNum)) return (aNum - bNum) * _sortDir;
    return aText.localeCompare(bText) * _sortDir;
  });

  // Re-append each leaderboard row followed by its breakdown row
  rows.forEach(function(r) {
    tbody.appendChild(r);
    var sectorId = r.dataset.sectorId;
    if (sectorId) {
      var bd = document.getElementById('bd-' + sectorId);
      if (bd) tbody.appendChild(bd);
    }
  });
}
</script>

</body>
</html>

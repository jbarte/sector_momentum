<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Sector Momentum — Themes</title>
<script src="{{ plotly_bundle }}"></script>
<style>
{% include "_style.html.j2" %}
</style>
</head>
<body>
{% set active_segment = "themes" %}
{% include '_header.html.j2' %}

<!-- Tab bar -->
<nav class="tabs" role="tablist">
  <button class="tab-btn active" onclick="switchTab('leaderboard', this)" role="tab" aria-selected="true" aria-controls="tab-leaderboard" data-i18n="tab_leaderboard">Leaderboard</button>
  <button class="tab-btn" onclick="switchTab('rrg', this)" role="tab" aria-selected="false" aria-controls="tab-rrg" data-i18n="tab_rrg">RRG</button>
  <button class="tab-btn" onclick="switchTab('drilldown', this)" role="tab" aria-selected="false" aria-controls="tab-drilldown" data-i18n="tab_drilldown">Drill-down</button>
  <button class="tab-btn" onclick="switchTab('movers', this)" role="tab" aria-selected="false" aria-controls="tab-movers" data-i18n="tab_movers">Movers</button>
  <button class="tab-btn" onclick="switchTab('history', this)" role="tab" aria-selected="false" aria-controls="tab-history" data-i18n="tab_history">History</button>
  <button class="tab-btn" onclick="switchTab('guide', this)" role="tab" aria-selected="false" aria-controls="tab-guide" data-i18n="tab_guide">Guide</button>
</nav>

<!-- ============================================================
     Tab: Leaderboard
     ============================================================ -->
<section id="tab-leaderboard" class="tab-panel active" role="tabpanel">
  <p class="tab-note" data-i18n="note_themes">Thematic ETFs ranked by the same momentum pillars, vs a global benchmark (ACWI). Information-only; separate from the sector leaderboard.</p>
  <div class="table-wrap">
    <table id="themes-table">
      <thead>
        <tr>
          <th data-i18n="col_rank">#</th>
          <th data-i18n="col_theme">Theme</th>
          <th data-i18n="col_composite">Composite</th>
          <th data-i18n="col_level">Level</th>
          <th data-i18n="col_change">Change</th>
          <th data-i18n="col_data">Data</th>
          <th data-i18n="col_rankdelta">Rank Δ</th>
          <th data-i18n="col_trend">Trend</th>
        </tr>
      </thead>
      <tbody>
        {% for row in theme_rows %}
        <tr class="leaderboard-row" data-sector-id="{{ row.sector_id }}" tabindex="0">
          <td class="rank-cell">
            <span class="rank-badge{% if row.rank is number and row.rank <= 3 %} top3{% endif %}">{{ row.rank }}</span>
            <span class="chevron" id="chev-{{ row.sector_id }}">▶</span>
          </td>
          <td>{{ row.theme }}{% if row.setup == "entry" %}<span class="setup-badge entry" data-i18n="badge_entry">▲ Entry</span>{% elif row.setup == "exit" %}<span class="setup-badge exit" data-i18n="badge_exit">▼ Exit</span>{% endif %}</td>
          <td class="composite-cell">{{ row.composite }}</td>
          <td>{{ row.level_score }}</td>
          <td>{{ row.change_score }}</td>
          <td>{{ row.data_score }}</td>
          <td class="delta-cell">
            {% if row.arrow %}<span class="arrow {{ row.arrow_class }}">{{ row.arrow }}</span> {% endif %}{{ row.delta_rank }}
          </td>
          <td>
            <span class="traj-badge traj-{{ row.trajectory_state }}">{{ row.trajectory_label }}</span>
          </td>
        </tr>
        <tr class="breakdown-row" id="bd-{{ row.sector_id }}">
          <td colspan="8">{{ row.breakdown_html | safe }}</td>
        </tr>
        {% else %}
        <tr><td colspan="8" style="text-align:center;padding:24px;color:var(--fg4)" data-i18n="themes_empty">No theme data yet — run a scan.</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>

<!-- ============================================================
     Tab: RRG
     ============================================================ -->
<section id="tab-rrg" class="tab-panel" role="tabpanel">
  <details class="tab-guide">
    <summary data-i18n="guide_summary">How to read this tab</summary>
    <div class="tab-guide-body" data-i18n-html="guide_body_rrg_themes">
      <p>Themes are plotted by <strong>relative strength vs benchmark</strong> (x-axis) and whether that relative strength is <strong>accelerating or decelerating</strong> (y-axis). Both axes are centred at 100.</p>
      <h4>Four quadrants</h4>
      <ul>
        <li><strong>Leading (top-right):</strong> Outperforming AND accelerating.</li>
        <li><strong>Weakening (bottom-right):</strong> Outperforming but decelerating. <span class="signal-lo">Prime exit / reduce signal.</span></li>
        <li><strong>Lagging (bottom-left):</strong> Underperforming AND decelerating. Avoid.</li>
        <li><strong>Improving (top-left):</strong> Underperforming but accelerating. <span class="signal-hi">Prime entry signal.</span></li>
      </ul>
      <h4>How to use</h4>
      <p>Themes rotate Leading → Weakening → Lagging → Improving → Leading. Buy in <span class="signal-hi">Improving</span> before the move to Leading; sell in <span class="signal-lo">Weakening</span> before the drop to Lagging. Dotted tail lines show the last scan positions — the direction of the tail matters more than the current position.</p>
    </div>
  </details>
  <div class="chart-container" id="rrg-chart" style="height:520px"></div>
</section>

<!-- ============================================================
     Tab: Drill-down
     ============================================================ -->
<section id="tab-drilldown" class="tab-panel" role="tabpanel">
  <details class="tab-guide">
    <summary data-i18n="guide_summary">How to read this tab</summary>
    <div class="tab-guide-body" data-i18n-html="guide_body_drilldown_themes">
      <p>Select a theme to see its score component history across all stored scans.</p>
      <h4>Key patterns</h4>
      <ul>
        <li><span class="signal-hi">Composite rising + Change score rising:</span> sustained acceleration. Highest-conviction entry setup.</li>
        <li><span class="signal-lo">Composite near peak + Change score turning negative:</span> the theme is topping. Reduce or exit.</li>
        <li>Composite falling but Change score rising: bottoming process. Watch for confirmation before entering.</li>
      </ul>
    </div>
  </details>
  <div class="drilldown-controls">
    <label for="theme-select">Theme:</label>
    <select class="sector-select" id="theme-select" onchange="updateDrilldown()">
      {% for sk in theme_keys %}
      <option value="{{ sk }}">{{ sk }}</option>
      {% endfor %}
    </select>
  </div>
  <div class="chart-container" id="drilldown-chart" style="height:460px"></div>
</section>

<!-- ============================================================
     Tab: Movers
     ============================================================ -->
<section id="tab-movers" class="tab-panel" role="tabpanel">
  <details class="tab-guide">
    <summary data-i18n="guide_summary">How to read this tab</summary>
    <div class="tab-guide-body" data-i18n-html="guide_body_movers_themes">
      <p>Rank change between the two most recent scans. <span class="signal-hi">Green bars</span> = themes that climbed the leaderboard; <span class="signal-lo">terracotta bars</span> = themes that slipped.</p>
      <h4>How to use</h4>
      <ul>
        <li>A single large positive move can be noise — confirm in the Drill-down tab before acting.</li>
        <li>Themes with 2+ consecutive large positive moves in the History tab carry more conviction.</li>
      </ul>
    </div>
  </details>
  <div class="chart-container" id="movers-chart"></div>
</section>

<!-- ============================================================
     Tab: History
     ============================================================ -->
<section id="tab-history" class="tab-panel" role="tabpanel">
  <details class="tab-guide">
    <summary data-i18n="guide_summary">How to read this tab</summary>
    <div class="tab-guide-body" data-i18n-html="guide_body_history_themes">
      <p>Composite score trend across all stored scans for every theme. The composite is a cross-sectional z-score — 0 = theme-average for that scan.</p>
      <h4>Key patterns</h4>
      <ul>
        <li><span class="signal-hi">Consistent upward slope:</span> quality momentum sustained over multiple scans.</li>
        <li><span class="signal-lo">Sharp spike then reversal:</span> likely a one-time event, not sustainable.</li>
        <li>Gradual recovery from negative territory: potential emerging opportunity.</li>
      </ul>
    </div>
  </details>
  <div class="chart-container" id="history-chart" style="height:520px"></div>
</section>

<!-- ============================================================
     Tab: Guide
     ============================================================ -->
<section id="tab-guide" class="tab-panel" role="tabpanel">
  <div class="guide" data-i18n-html="guide_tab_themes">
    <h2>Leaderboard</h2>
    <p>
      The leaderboard ranks every thematic ETF by its <strong>composite score</strong> — a
      weighted blend of level, momentum-change, and data-quality sub-scores measured against
      a global benchmark (ACWI). A higher composite means the theme is exhibiting stronger
      relative momentum.
    </p>
    <ul>
      <li><strong>Level score</strong> — current absolute momentum level (returns, MA structure, OBV trend).</li>
      <li><strong>Change score</strong> — how momentum is accelerating or decelerating versus the prior scan.</li>
      <li><strong>Data score</strong> — data completeness; themes with missing signals are penalised.</li>
      <li><strong>Rank Δ</strong> — how many ranks the theme climbed (▲) or fell (▼) versus the previous scan.</li>
    </ul>
    <p>Click any row to see the full signal breakdown and UCITS alternative instruments.</p>

    <h2>Relative Rotation Graph (RRG)</h2>
    <p>
      The RRG plots themes on two axes derived from their relative strength vs the benchmark:
    </p>
    <ul>
      <li><strong>X-axis (RS-Ratio)</strong> — whether the theme is outperforming (&gt; 100) or underperforming (&lt; 100) the benchmark.</li>
      <li><strong>Y-axis (RS-Momentum)</strong> — whether relative strength is accelerating (&gt; 100) or decelerating (&lt; 100).</li>
    </ul>
    <p>
      Dotted tail lines show the last scan positions per theme, indicating rotation direction.
      Themes rotating from Improving → Leading are the strongest early-trend setups.
    </p>

    <h2>Drill-down</h2>
    <p>
      Select a theme from the dropdown to view how each score component has evolved over time.
      A rising <em>change_score</em> alongside a rising <em>composite</em> signals sustained momentum.
    </p>

    <h2>Movers</h2>
    <p>
      Rank change between the two most recent scans.
      <span style="color:var(--up)">Green bars</span> indicate themes that climbed;
      <span style="color:var(--down)">terracotta bars</span> indicate themes that slipped.
    </p>

    <h2>History</h2>
    <p>
      A line chart of composite score across all stored scans. Persistent upward trends
      indicate sustained momentum; reversals may signal rotation into or out of the theme.
    </p>

    <h2>Disclaimer</h2>
    <p>
      <strong>This tool is for analytical and educational purposes only.</strong>
      It does not constitute investment advice. Past momentum is not indicative of future
      returns. Always perform your own due diligence.
    </p>
  </div>
</section>

<!-- ============================================================
     JavaScript
     ============================================================ -->
<script>
{% include '_tabs.js.j2' %}

// ----- Plotly data (injected by build.py) -----
var RRG_DATA       = {{ theme_rrg_json | js_json }};
var MOVERS_DATA    = {{ theme_movers_json | js_json }};
var HISTORY_DATA   = {{ theme_history_json | js_json }};
var DRILLDOWN_DATA = {{ theme_drilldown_data | js_json }};

// ----- Render helpers -----
var _rendered = {};

function renderRRG() {
  if (_rendered.rrg) return;
  _rendered.rrg = true;
  Plotly.newPlot('rrg-chart', RRG_DATA.data, RRG_DATA.layout, {responsive: true, displayModeBar: true});
}

function renderMovers() {
  if (_rendered.movers) return;
  _rendered.movers = true;
  Plotly.newPlot('movers-chart', MOVERS_DATA.data, MOVERS_DATA.layout, {responsive: true, displayModeBar: true});
}

function renderHistory() {
  if (_rendered.history) return;
  _rendered.history = true;
  Plotly.newPlot('history-chart', HISTORY_DATA.data, HISTORY_DATA.layout, {responsive: true, displayModeBar: true});
}

function renderDrilldown() {
  _rendered.drilldown = false;
  updateDrilldown();
}

function updateDrilldown() {
  var sel = document.getElementById('theme-select');
  if (!sel) return;
  var key = sel.value;
  var figJson = DRILLDOWN_DATA[key];
  if (!figJson) {
    document.getElementById('drilldown-chart').innerHTML =
      '<p style="padding:24px;color:var(--fg4)">No data for ' + key + '</p>';
    return;
  }
  var fig = typeof figJson === 'string' ? JSON.parse(figJson) : figJson;
  Plotly.newPlot('drilldown-chart', fig.data, fig.layout, {responsive: true, displayModeBar: true});
}

// ----- Breakdown toggle -----
function toggleBreakdown(id) {
  var bd = document.getElementById("bd-" + id);
  var chev = document.getElementById("chev-" + id);
  if (!bd) return;
  var open = bd.classList.toggle("open");
  if (chev) chev.textContent = open ? "▼" : "▶";
}
// Delegated click handler for theme row expansion
document.getElementById('themes-table')?.addEventListener('click', function(e) {
  var row = e.target.closest('.leaderboard-row');
  if (row) {
    var id = row.getAttribute('data-sector-id');
    if (id) toggleBreakdown(id);
  }
});

// Keyboard support for interactive table elements
document.getElementById('themes-table')?.addEventListener('keydown', function(e) {
  if (e.key !== 'Enter' && e.key !== ' ') return;
  var t = e.target;
  if (t.matches('th[onclick]') || t.matches('.leaderboard-row')) {
    e.preventDefault();
    t.click();
  }
});

{% include "_i18n.html.j2" %}
</script>

{% include "_guide_modal.html.j2" %}

</body>
</html>
